---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, type CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config';

type FormationEntry = CollectionEntry<'formations'>;

const formations = await getCollection(
  'formations',
  ({ data }: { data: FormationEntry['data'] }) => !data.draft
);

const results = [...formations].sort(
  (a: FormationEntry, b: FormationEntry) => a.data.order - b.data.order
);

const totalResults = results.length;

const domainMap = results.reduce(
  (acc, item) => {
    const domain = item.data.domain;
    const subdomain = item.data.subdomain;

    if (!acc[domain]) {
      acc[domain] = { count: 0, subdomains: {} as Record<string, number> };
    }
    acc[domain].count += 1;

    if (subdomain) {
      acc[domain].subdomains[subdomain] = (acc[domain].subdomains[subdomain] || 0) + 1;
    }

    return acc;
  },
  {} as Record<string, { count: number; subdomains: Record<string, number> }>
);

const badgeClassMap: Record<string, string> = {
  incontournable: 'bg-[#ef5b5b] text-white',
  nouveaute: 'bg-primary-dark text-white',
  expert: 'bg-primary text-white',
  certifiant: 'bg-success text-white',
};

const domainEntries = Object.entries(domainMap) as Array<
  [string, { count: number; subdomains: Record<string, number> }]
>;
---

<MarketingLayout
  title={`Formations - ${siteConfig.name}`}
  description="Votre recherche de formations SODEVA : filtrez par domaine et consultez les parcours avec badges et visuels."
>
  <section class="hero-search">
    <div class="hero-overlay">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-16">
        <p class="text-sm text-white/90">Accueil / Votre recherche</p>
        <h1 class="mt-4 text-3xl sm:text-4xl font-bold text-white">Votre recherche</h1>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-[340px_1fr]">
        <aside class="space-y-6">
          <h2 class="text-3xl font-semibold text-primary-dark">Filtrer par</h2>

          <div class="rounded-2xl border border-border bg-background p-6">
            <div class="mb-4 flex items-center justify-between">
              <h3 class="text-2xl font-semibold text-primary-dark">Domaines</h3>
              <Icon name="lucide:chevron-up" class="h-6 w-6 text-primary" />
            </div>

            <div class="space-y-3 text-lg text-primary-dark" id="domain-filters">
              <label class="flex items-center gap-3">
                <input
                  type="checkbox"
                  class="h-5 w-5 rounded border-border"
                  data-domain-filter="all"
                  checked
                />
                <span>Tous ({totalResults})</span>
              </label>
              {
                domainEntries.map(([domain, info]) => (
                  <div>
                    <label class="flex items-center gap-3">
                      <input
                        type="checkbox"
                        class="h-5 w-5 rounded border-border"
                        data-domain-filter={domain}
                      />
                      <span>{domain} ({info.count})</span>
                    </label>
                    {Object.entries(info.subdomains).length > 0 && (
                      <div class="ml-8 mt-2 space-y-2 text-base text-text-muted">
                        {Object.entries(info.subdomains).map(([subdomain, count]) => (
                          <p>{subdomain} ({count})</p>
                        ))}
                      </div>
                    )}
                  </div>
                ))
              }
            </div>
          </div>
        </aside>

        <div>
          <p class="text-2xl font-semibold text-primary-dark">
            <span id="results-count">{totalResults}</span>
            {' '}
            resultats pour votre recherche
          </p>
          <p class="mt-1 text-sm text-text-muted">Formations disponibles selon le domaine selectionne.</p>

          <div class="mt-6 space-y-6" id="formation-results">
            {
              results.map((formation) => (
                <article
                  class="rounded-2xl border border-border bg-background p-6 formation-card"
                  data-domain={formation.data.domain}
                >
                  <div class="flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
                    <div class="w-full">
                      <div class="mb-4 flex flex-wrap items-center gap-2">
                        <span class="rounded-md bg-primary-dark px-3 py-1 text-xs font-semibold text-white">
                          {formation.data.subdomain || formation.data.domain}
                        </span>
                        <span
                          class:list={[
                            'rounded-md px-3 py-1 text-xs font-semibold',
                            badgeClassMap[formation.data.badgeTone] ||
                              'bg-primary text-white',
                          ]}
                        >
                          {formation.data.badgeLabel}
                        </span>
                      </div>

                      <div class="grid gap-5 md:grid-cols-[200px_1fr]">
                        <div class="overflow-hidden rounded-xl bg-surface">
                          {formation.data.image ? (
                            <img
                              src={formation.data.image}
                              alt={formation.data.title}
                              class="h-full min-h-36 w-full object-cover"
                              loading="lazy"
                            />
                          ) : (
                            <div class="flex h-full min-h-36 items-center justify-center bg-linear-to-br from-slate-100 to-slate-200 text-sm font-medium text-text-muted">
                              VISUEL
                            </div>
                          )}
                        </div>

                        <div>
                          <h2 class="text-2xl font-semibold leading-tight text-primary-dark">
                            {formation.data.title}
                          </h2>
                          <p class="mt-2 text-base font-medium text-text-muted">{formation.data.domain}</p>
                          <p class="mt-3 text-base leading-relaxed text-text-muted">
                            {formation.data.description}
                          </p>
                          <div class="mt-3 flex items-center gap-2 text-primary">
                            <div class="flex items-center gap-1">
                              {Array.from({ length: 5 }).map(() => (
                                <Icon name="lucide:star" class="h-4 w-4 fill-current" />
                              ))}
                            </div>
                            <span class="text-base font-semibold text-primary-dark">
                              {formation.data.rating.toFixed(1)}
                            </span>
                            <span class="text-base text-primary-dark">/5 ({formation.data.reviews} avis)</span>
                          </div>
                        </div>
                      </div>

                      <div class="mt-6 border-t border-border pt-4">
                        <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-base text-text-muted">
                          <span class="inline-flex items-center gap-2">
                            <Icon name="lucide:clock-3" class="h-5 w-5" />
                            {formation.data.duration}
                          </span>
                          <span class="inline-flex items-center gap-2">
                            <Icon name="lucide:map-pin" class="h-5 w-5" />
                            {formation.data.format}
                          </span>
                          <span class="inline-flex items-center gap-2">
                            <Icon name="lucide:chart-column" class="h-5 w-5" />
                            {formation.data.level}
                          </span>
                          {formation.data.guaranteedSession && (
                            <span class="inline-flex items-center gap-2 rounded-md bg-primary/15 px-3 py-1.5 text-xs font-semibold text-primary-dark">
                              <Icon name="lucide:badge-check" class="h-4 w-4" />
                              SESSION GARANTIE
                            </span>
                          )}
                        </div>
                      </div>
                    </div>

                    <div class="flex min-w-fit flex-row items-end justify-between gap-5 xl:flex-col xl:items-end">
                      <div class="text-right">
                        <p class="text-4xl font-bold text-primary-dark">
                          {formation.data.priceHT.toLocaleString('fr-FR')} € HT
                        </p>
                        <p class="mt-2 inline-flex items-center gap-2 text-base text-text-muted">
                          <Icon name="lucide:tag" class="h-5 w-5" />
                          Ref {formation.data.reference}
                        </p>
                      </div>
                      <a
                        href={`/formation/${formation.id}`}
                        aria-label={`Voir ${formation.data.title}`}
                        class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary text-white"
                      >
                        <Icon name="lucide:arrow-right" class="h-5 w-5" />
                      </a>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .hero-search {
    background-image:
      linear-gradient(100deg, rgb(15 15 15 / 86%), rgb(250 133 49 / 45%)),
      url('/images/og-image.png');
    background-position: center;
    background-size: cover;
  }
</style>

<script>
  const filterContainer = document.getElementById('domain-filters');
  const resultsContainer = document.getElementById('formation-results');
  const resultCountEl = document.getElementById('results-count');

  if (filterContainer && resultsContainer && resultCountEl) {
    const checkboxes = Array.from(
      filterContainer.querySelectorAll<HTMLInputElement>(
        'input[type="checkbox"][data-domain-filter]'
      )
    );
    const cards = Array.from(resultsContainer.querySelectorAll<HTMLElement>('.formation-card'));
    const allFilter = filterContainer.querySelector<HTMLInputElement>(
      'input[data-domain-filter="all"]'
    );

    const syncAllToggle = () => {
      const domainChecks = checkboxes.filter((el) => el !== allFilter);
      const selectedDomains = domainChecks.filter((el) => el.checked);
      if (!allFilter) return;

      if (selectedDomains.length === 0) {
        allFilter.checked = true;
      } else {
        allFilter.checked = false;
      }
    };

    const applyFilters = () => {
      const selectedDomains = checkboxes
        .filter((el) => el !== allFilter && el.checked)
        .map((el) => el.getAttribute('data-domain-filter'));

      let visibleCount = 0;

      cards.forEach((card) => {
        const domain = card.getAttribute('data-domain');
        const show = selectedDomains.length === 0 || selectedDomains.includes(domain);
        card.style.display = show ? '' : 'none';
        if (show) visibleCount += 1;
      });

      resultCountEl.textContent = String(visibleCount);
    };

    checkboxes.forEach((checkbox) => {
      checkbox.addEventListener('change', (event) => {
        const target = event.currentTarget;
        if (!(target instanceof HTMLInputElement)) return;

        if (target === allFilter && target.checked) {
          checkboxes.forEach((el) => {
            if (el !== allFilter) el.checked = false;
          });
        } else if (target !== allFilter && target.checked && allFilter instanceof HTMLInputElement) {
          allFilter.checked = false;
        }

        syncAllToggle();
        applyFilters();
      });
    });

    applyFilters();
  }
</script>

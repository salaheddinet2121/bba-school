---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';
import { beautyFormations } from '@/data/beauty-formations';

const offers = [
  { price: '1 300 €', label: '3 formations au choix' },
  { price: '1 650 €', label: '4 formations au choix' },
  { price: '2 950 €', label: '8 formations au choix' },
];

// Group by category
const byCategory = beautyFormations.reduce((acc, f) => {
  if (!acc[f.category]) acc[f.category] = [];
  acc[f.category].push(f);
  return acc;
}, {} as Record<string, typeof beautyFormations>);
---

<MarketingLayout
  title={`Nos formations — ${siteConfig.name}`}
  description="39 formations esthétique à distance certifiées Qualiopi : Hydrofacial, Plasma pen, Microblading, Épilation définitive et bien plus. Éligibles CPF, kit offert."
>
  <PageHeader
    title="Nos formations"
    subtitle="39 formations esthétique à distance, éligibles CPF. Kit ou machine offerts selon la formation."
    align="left"
  />

  <section class="py-16 border-t border-border">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">

      <!-- Offres multi-formations -->
      <div class="mb-16">
        <p class="section-kicker mb-6">Offres groupées</p>
        <div class="grid sm:grid-cols-3 gap-px bg-border">
          {offers.map((offer, i) => (
            <div class:list={['p-8', i === 1 ? 'accent-pink' : 'bg-white']}>
              <p class="section-title text-4xl text-text">{offer.price}</p>
              <p class="mt-2 text-sm text-text-muted">{offer.label}</p>
            </div>
          ))}
        </div>
        <div class="mt-4 flex items-center justify-between border-t border-border pt-4">
          <p class="text-sm text-text-muted">Contactez-nous pour composer votre sélection.</p>
          <a href="/contact" class="site-button-primary inline-flex items-center gap-2 rounded-none px-5 py-2.5">
            Nous contacter
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </div>

      <!-- Catalogue par catégorie -->
      <div class="space-y-12">
        {Object.entries(byCategory).map(([category, formations]) => (
          <div>
            <p class="section-kicker mb-4">{category}</p>
            <div class="border-t border-border">
              {formations.map((f) => (
                <div class="grid grid-cols-[1fr_auto] items-baseline gap-8 border-b border-border py-4">
                  <div class="flex items-baseline gap-3">
                    <span class="text-base text-text">{f.title}</span>
                    {f.note && (
                      <span class="text-xs text-text-muted shrink-0">{f.note}</span>
                    )}
                  </div>
                  <span class="text-base font-medium text-text tabular-nums shrink-0">{f.price}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA bas de page -->
      <div class="mt-16 border-t border-border pt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
        <div>
          <p class="section-title text-2xl text-text">Prêt à vous former ?</p>
          <p class="mt-2 text-sm text-text-muted">Contactez-nous pour démarrer votre parcours.</p>
        </div>
        <a href="/contact" class="site-button-primary shrink-0 inline-flex items-center gap-2 rounded-none px-6 py-3">
          Demander une formation
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
      </div>

    </div>
  </section>
</MarketingLayout>

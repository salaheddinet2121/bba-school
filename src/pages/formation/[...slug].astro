---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config';

type FormationEntry = CollectionEntry<'formations'>;

export async function getStaticPaths() {
  const formations = await getCollection(
    'formations',
    ({ data }: { data: FormationEntry['data'] }) => !data.draft
  );

  return formations.map((formation: FormationEntry) => ({
    params: { slug: formation.id },
    props: { formation },
  }));
}

interface Props {
  formation: FormationEntry;
}

const { formation } = Astro.props;
const { Content } = await render(formation);
---

<MarketingLayout
  title={`${formation.data.title} - ${siteConfig.name}`}
  description={formation.data.description}
  image={formation.data.image}
>
  <section class="py-12 sm:py-16 bg-background">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/formation" class="inline-flex items-center gap-2 text-sm text-primary hover:underline">
        <Icon name="lucide:arrow-left" class="h-4 w-4" />
        Retour au catalogue
      </a>

      <div class="mt-6 overflow-hidden rounded-3xl border border-border bg-background">
        <div class="grid gap-0 md:grid-cols-[340px_1fr]">
          <div class="bg-surface">
            {formation.data.image ? (
              <img
                src={formation.data.image}
                alt={formation.data.title}
                class="h-full min-h-56 w-full object-cover"
              />
            ) : (
              <div class="flex h-full min-h-56 items-center justify-center bg-linear-to-br from-slate-100 to-slate-200 text-sm font-medium text-text-muted">
                VISUEL FORMATION
              </div>
            )}
          </div>

          <div class="p-6 sm:p-8">
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-md bg-[#2f5f97] px-3 py-1 text-xs font-semibold text-white">
                {formation.data.subdomain || formation.data.domain}
              </span>
              <span class="rounded-md bg-primary px-3 py-1 text-xs font-semibold text-white">
                {formation.data.badgeLabel}
              </span>
            </div>

            <h1 class="mt-4 text-3xl sm:text-4xl font-bold text-primary-dark">{formation.data.title}</h1>
            <p class="mt-3 text-lg text-text-muted">{formation.data.description}</p>

            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              <p class="rounded-lg border border-border bg-background px-4 py-3 text-sm text-text-muted">
                <strong class="text-primary-dark">Duree:</strong> {formation.data.duration}
              </p>
              <p class="rounded-lg border border-border bg-background px-4 py-3 text-sm text-text-muted">
                <strong class="text-primary-dark">Format:</strong> {formation.data.format}
              </p>
              <p class="rounded-lg border border-border bg-background px-4 py-3 text-sm text-text-muted">
                <strong class="text-primary-dark">Niveau:</strong> {formation.data.level}
              </p>
              <p class="rounded-lg border border-border bg-background px-4 py-3 text-sm text-text-muted">
                <strong class="text-primary-dark">Tarif:</strong> {formation.data.priceHT.toLocaleString('fr-FR')} € HT
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 grid gap-4 rounded-2xl border border-border p-5 sm:grid-cols-2">
        <p class="text-sm text-text-muted">
          <strong class="text-primary-dark">Objectifs:</strong> {formation.data.objectifs}
        </p>
        <p class="text-sm text-text-muted">
          <strong class="text-primary-dark">Public:</strong> {formation.data.public}
        </p>
      </div>

      <article class="mt-10 rounded-2xl border border-border bg-background p-6 sm:p-8">
        <h2 class="text-2xl font-semibold text-primary-dark">Programme de la formation</h2>
        <div class="mt-5 formation-content text-text-muted leading-relaxed">
        <Content />
        </div>
      </article>
    </div>
  </section>
</MarketingLayout>

<style>
  .formation-content :global(h2) {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    line-height: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    border-bottom: 0;
    padding-bottom: 0;
  }

  .formation-content :global(h3) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
    line-height: 1.4rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .formation-content :global(p) {
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .formation-content :global(ul) {
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
    padding-left: 1.1rem;
    list-style: disc;
  }

  .formation-content :global(li) {
    margin-top: 0.35rem;
  }
 </style>

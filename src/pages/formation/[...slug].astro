---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { siteConfig } from '@/config';
import ReservationCard from '@components/formation/ReservationCard.astro';

type FormationEntry = CollectionEntry<'formations'>;

export async function getStaticPaths() {
  const formations = await getCollection(
    'formations',
    ({ data }: { data: FormationEntry['data'] }) => !data.draft
  );

  return formations.map((formation: FormationEntry) => ({
    params: { slug: formation.id },
    props: { formation },
  }));
}

interface Props {
  formation: FormationEntry;
}

const { formation } = Astro.props;
const { Content } = await render(formation);
type ProgrammeModule = (typeof formation.data.programmeModules)[number];

const objectifs = formation.data.objectifsPoints.length
  ? formation.data.objectifsPoints
  : [formation.data.objectifs];

const hasRating = formation.data.rating > 0 && formation.data.reviews > 0;

const modePrices = {
  distanciel: formation.data.distancielAvailable
    ? (formation.data.distancielPriceHT ?? formation.data.priceHT)
    : null,
  presentiel: formation.data.presentielAvailable
    ? (formation.data.presentielPriceHT ?? formation.data.priceHT)
    : null,
};

const defaultMode =
  modePrices.distanciel !== null
    ? 'distanciel'
    : modePrices.presentiel !== null
      ? 'presentiel'
      : 'distanciel';

const defaultPrice = modePrices[defaultMode] ?? formation.data.priceHT;
const formatPrice = (value: number) => `${value.toLocaleString('fr-FR')} EUR HT`;
const priceFallbackMessage = formation.data.pricingText ?? 'Tarif sur demande';
const getDisplayPrice = (value: number | null | undefined) =>
  typeof value === 'number' && Number.isFinite(value) && value > 0
    ? formatPrice(value)
    : priceFallbackMessage;
const defaultPriceLabel = getDisplayPrice(defaultPrice);
const defaultQuoteHref = `/demande-devis?formation=${encodeURIComponent(formation.id)}&type=${defaultMode}`;
---

<MarketingLayout
  title={`${formation.data.title} - ${siteConfig.name}`}
  description={formation.data.description}
  image={formation.data.image}
>
  <section class="formation-hero py-10 sm:py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-white/90">
        <a href="/" class="underline-offset-2 hover:underline">Accueil</a>
        {' / '}
        <a href="/formation" class="underline-offset-2 hover:underline">Formations</a>
        {' / '}
        {formation.data.domain}
        {formation.data.subdomain ? ` / ${formation.data.subdomain}` : ''}
      </p>

      <h1 class="mt-4 text-2xl sm:text-3xl font-bold leading-tight text-white">
        {formation.data.title}
      </h1>
      <p class="mt-3 max-w-4xl text-sm sm:text-base text-white/85">{formation.data.description}</p>

      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span
          class="inline-flex items-center rounded-md bg-primary px-2.5 py-1 text-xs font-semibold text-white"
        >
          {formation.data.badgeLabel}
        </span>
        <span
          class="inline-flex items-center rounded-md bg-white/15 px-2.5 py-1 text-xs font-medium text-white"
        >
          {formation.data.domain}
        </span>
        {
          formation.data.subdomain && (
            <span class="inline-flex items-center rounded-md bg-white/15 px-2.5 py-1 text-xs font-medium text-white">
              {formation.data.subdomain}
            </span>
          )
        }
      </div>

      {
        hasRating && (
          <div class="mt-4 flex items-center gap-2 text-primary">
            <div class="flex items-center gap-1">
              {Array.from({ length: 5 }).map(() => (
                <Icon name="lucide:star" class="h-4 w-4 fill-current" />
              ))}
            </div>
          </div>
        )
      }

      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-white">
        {
          formation.data.guaranteedSession && (
            <span class="inline-flex items-center gap-2 rounded-md bg-info px-3 py-1.5 text-xs font-semibold text-white">
              <Icon name="lucide:badge-check" class="h-4 w-4" />
              SESSION GARANTIE
            </span>
          )
        }
        <span class="inline-flex items-center gap-2">
          <Icon name="lucide:clock-3" class="h-4 w-4" />
          {formation.data.duration}
        </span>
        <span class="inline-flex items-center gap-2">
          <Icon name="lucide:map-pin" class="h-4 w-4" />
          {formation.data.format}
        </span>
        <span class="inline-flex items-center gap-2">
          <Icon name="lucide:chart-column" class="h-4 w-4" />
          {formation.data.level}
        </span>
      </div>
    </div>
  </section>

  <section class="sticky top-[72px] z-20 border-y border-border bg-background/95 backdrop-blur">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="overflow-x-auto py-3" aria-label="Navigation formation">
        <ul class="flex min-w-max items-center gap-2 text-sm font-semibold">
          <li>
            <a data-anchor-link href="#description" class="anchor-pill">Description</a>
          </li>
          <li>
            <a data-anchor-link href="#objectifs" class="anchor-pill">Objectifs</a>
          </li>
          <li>
            <a data-anchor-link href="#prerequis" class="anchor-pill">Prérequis</a>
          </li>
          <li>
            <a data-anchor-link href="#public" class="anchor-pill">Public cible</a>
          </li>
          <li>
            <a data-anchor-link href="#programme" class="anchor-pill">Programme</a>
          </li>
        </ul>
      </nav>
    </div>
  </section>

  <section class="py-10 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[1fr_400px]">
        <div class="space-y-4">
          <article id="description" class="scroll-mt-40">
            <details class="group section-panel" open>
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4"
              >
                <span class="inline-flex items-center gap-3">
                  <span class="section-icon">
                    <Icon name="lucide:file-text" class="h-4 w-4" />
                  </span>
                  <span class="text-lg font-semibold text-primary-dark"
                    >Description de la formation</span
                  >
                </span>
                <Icon
                  name="lucide:chevron-down"
                  class="h-5 w-5 text-text-muted transition-transform duration-300 group-open:rotate-180"
                />
              </summary>
              <div class="px-5 pb-5">
                <p class="text-sm leading-relaxed text-text-muted">{formation.data.description}</p>
                <div class="mt-4 grid gap-3 sm:grid-cols-2">
                  <div class="detail-item">
                    <Icon name="lucide:clock-3" class="h-4 w-4 text-primary" />
                    <span>Durée: {formation.data.duration}</span>
                  </div>
                  <div class="detail-item">
                    <Icon name="lucide:map-pin" class="h-4 w-4 text-primary" />
                    <span>Format: {formation.data.format}</span>
                  </div>
                  <div class="detail-item">
                    <Icon name="lucide:chart-column" class="h-4 w-4 text-primary" />
                    <span>Niveau: {formation.data.level}</span>
                  </div>
                  <div class="detail-item">
                    <Icon name="lucide:hash" class="h-4 w-4 text-primary" />
                    <span>Référence: {formation.data.reference}</span>
                  </div>
                  <div class="detail-item">
                    <Icon name="lucide:badge-percent" class="h-4 w-4 text-primary" />
                    <span>Taux de réussite: 100%</span>
                  </div>
                </div>
              </div>
            </details>
          </article>

          <article id="objectifs" class="scroll-mt-40">
            <details class="group section-panel" open>
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4"
              >
                <span class="inline-flex items-center gap-3">
                  <span class="section-icon">
                    <Icon name="lucide:target" class="h-4 w-4" />
                  </span>
                  <span class="text-lg font-semibold text-primary-dark">Objectifs pédagogiques</span
                  >
                </span>
                <Icon
                  name="lucide:chevron-down"
                  class="h-5 w-5 text-text-muted transition-transform duration-300 group-open:rotate-180"
                />
              </summary>
              <div class="px-5 pb-5">
                <ul class="space-y-2">
                  {
                    objectifs.map((item: string) => (
                      <li class="flex items-start gap-2.5 text-sm text-text-muted">
                        <span class="mt-1.5 h-2 w-2 rounded-full bg-primary" />
                        <span>{item}</span>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </details>
          </article>

          <article id="prerequis" class="scroll-mt-40">
            <details class="group section-panel" open>
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4"
              >
                <span class="inline-flex items-center gap-3">
                  <span class="section-icon">
                    <Icon name="lucide:list-checks" class="h-4 w-4" />
                  </span>
                  <span class="text-lg font-semibold text-primary-dark">Prérequis</span>
                </span>
                <Icon
                  name="lucide:chevron-down"
                  class="h-5 w-5 text-text-muted transition-transform duration-300 group-open:rotate-180"
                />
              </summary>
              <div class="px-5 pb-5">
                <p class="text-sm leading-relaxed text-text-muted">{formation.data.prerequis}</p>
              </div>
            </details>
          </article>

          <article id="public" class="scroll-mt-40">
            <details class="group section-panel" open>
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4"
              >
                <span class="inline-flex items-center gap-3">
                  <span class="section-icon">
                    <Icon name="lucide:users" class="h-4 w-4" />
                  </span>
                  <span class="text-lg font-semibold text-primary-dark">Public cible</span>
                </span>
                <Icon
                  name="lucide:chevron-down"
                  class="h-5 w-5 text-text-muted transition-transform duration-300 group-open:rotate-180"
                />
              </summary>
              <div class="px-5 pb-5">
                <p class="text-sm leading-relaxed text-text-muted">{formation.data.public}</p>
              </div>
            </details>
          </article>

          <article id="programme" class="scroll-mt-40">
            <details class="group section-panel" open>
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4"
              >
                <span class="inline-flex items-center gap-3">
                  <span class="section-icon">
                    <Icon name="lucide:book-open-check" class="h-4 w-4" />
                  </span>
                  <span class="text-lg font-semibold text-primary-dark"
                    >Programme de la formation</span
                  >
                </span>
                <Icon
                  name="lucide:chevron-down"
                  class="h-5 w-5 text-text-muted transition-transform duration-300 group-open:rotate-180"
                />
              </summary>
              <div class="px-5 pb-5">
                {
                  formation.data.programmeModules.length > 0 && (
                    <div class="space-y-3">
                      {formation.data.programmeModules.map(
                        (module: ProgrammeModule, index: number) => (
                          <details
                            class="rounded-lg border border-border bg-surface p-4"
                            open={index === 0}
                          >
                            <summary class="flex cursor-pointer list-none items-center gap-3 text-base font-semibold text-primary-dark">
                              <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-primary text-xs font-bold text-white">
                                {index + 1}
                              </span>
                              <span>{module.title}</span>
                            </summary>
                            <ul class="mt-3 space-y-2 pl-10">
                              {module.items.map((item: string) => (
                                <li class="text-sm text-text-muted">• {item}</li>
                              ))}
                            </ul>
                          </details>
                        )
                      )}
                    </div>
                  )
                }

                <div class="mt-6 rounded-xl border border-border bg-surface/60 p-5 sm:p-6">
                  <div class="flex items-center gap-3">
                    <span
                      class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-primary/15 text-primary"
                    >
                      <Icon name="lucide:file-text" class="h-4 w-4" />
                    </span>
                    <h3 class="text-base font-semibold text-primary-dark">
                      Informations complémentaires
                    </h3>
                  </div>
                  <div class="mt-4 formation-content text-sm text-text-muted leading-relaxed">
                    <Content />
                  </div>
                </div>
              </div>
            </details>
          </article>
        </div>

        <div class="lg:hidden">
          <ReservationCard
            formationId={formation.id}
            programmePdf={formation.data.programmePdf}
            distancielPrice={modePrices.distanciel}
            presentielPrice={modePrices.presentiel}
            priceFallbackMessage={priceFallbackMessage}
            defaultMode={defaultMode}
            defaultPriceLabel={defaultPriceLabel}
            defaultQuoteHref={defaultQuoteHref}
            nextSessionCity={formation.data.nextSessionCity}
            nextSessionDate={formation.data.nextSessionDate}
            duration={formation.data.duration}
            reference={formation.data.reference}
            distancielAvailable={formation.data.distancielAvailable}
            presentielAvailable={formation.data.presentielAvailable}
            mobile={true}
          />
        </div>

        <aside class="hidden lg:block">
          <ReservationCard
            formationId={formation.id}
            programmePdf={formation.data.programmePdf}
            distancielPrice={modePrices.distanciel}
            presentielPrice={modePrices.presentiel}
            priceFallbackMessage={priceFallbackMessage}
            defaultMode={defaultMode}
            defaultPriceLabel={defaultPriceLabel}
            defaultQuoteHref={defaultQuoteHref}
            nextSessionCity={formation.data.nextSessionCity}
            nextSessionDate={formation.data.nextSessionDate}
            duration={formation.data.duration}
            reference={formation.data.reference}
            distancielAvailable={formation.data.distancielAvailable}
            presentielAvailable={formation.data.presentielAvailable}
            sticky={true}
          />
        </aside>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .formation-hero {
    background-image:
      linear-gradient(100deg, rgb(15 15 15 / 88%), rgb(250 133 49 / 35%)), url('/images/hero.webp');
    background-position: center;
    background-size: cover;
  }

  .anchor-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.85rem;
    color: var(--color-primary-dark);
    transition: all 0.2s ease;
  }

  .anchor-pill:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .anchor-pill.is-active {
    border-color: var(--color-primary);
    background: var(--color-primary);
    color: white;
  }

  .section-panel {
    border-radius: 0.9rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 26%, white);
  }

  .section-icon {
    display: inline-flex;
    height: 1.75rem;
    width: 1.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-primary) 14%, white);
    color: var(--color-primary);
  }

  .detail-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 0.65rem;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    padding: 0.55rem 0.7rem;
    font-size: 0.83rem;
    color: var(--color-text-muted);
  }

  .mode-price {
    color: #0f0f0f;
    line-height: 1.2;
  }

  .formation-content :global(h2) {
    margin-top: 1rem;
    margin-bottom: 0.4rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-primary-dark);
  }

  .formation-content :global(h3) {
    margin-top: 0.8rem;
    margin-bottom: 0.3rem;
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--color-primary-dark);
  }

  .formation-content :global(p) {
    margin-top: 0.55rem;
    margin-bottom: 0.55rem;
    line-height: 1.7;
  }

  .formation-content :global(ul) {
    margin-top: 0.55rem;
    margin-bottom: 0.55rem;
    padding-left: 0;
    list-style: none;
  }

  .formation-content :global(li) {
    position: relative;
    margin-top: 0.4rem;
    padding-left: 1rem;
  }

  .formation-content :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    height: 0.38rem;
    width: 0.38rem;
    border-radius: 9999px;
    background: var(--color-primary);
  }
</style>

<script is:inline>
  const initAnchorNav = () => {
    const links = Array.from(document.querySelectorAll('a[data-anchor-link]'));
    if (!links.length) return;

    const sections = links
      .map((link) => {
        const hash = link.getAttribute('href');
        if (!hash || !hash.startsWith('#')) return null;
        return document.querySelector(hash);
      })
      .filter((section) => section instanceof HTMLElement);

    const setActiveLink = (hash) => {
      links.forEach((link) => {
        const isActive = link.getAttribute('href') === hash;
        link.classList.toggle('is-active', isActive);
      });
    };

    links.forEach((link) => {
      if (link.dataset.bound === 'true') return;
      link.dataset.bound = 'true';

      link.addEventListener('click', (event) => {
        const hash = link.getAttribute('href');
        if (!hash || !hash.startsWith('#')) return;
        const target = document.querySelector(hash);
        if (!(target instanceof HTMLElement)) return;

        event.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', hash);
        setActiveLink(hash);
      });
    });

    if (window.__formationAnchorObserver) {
      window.__formationAnchorObserver.disconnect();
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target?.id) {
          setActiveLink(`#${visible.target.id}`);
        }
      },
      {
        rootMargin: '-30% 0px -55% 0px',
        threshold: [0.1, 0.25, 0.5],
      }
    );

    sections.forEach((section) => observer.observe(section));
    window.__formationAnchorObserver = observer;

    const currentHash = window.location.hash;
    if (currentHash && document.querySelector(currentHash)) {
      setActiveLink(currentHash);
    } else {
      setActiveLink('#description');
    }
  };

  const initModeCard = () => {
    const modeCards = Array.from(document.querySelectorAll('[data-mode-card]'));

    modeCards.forEach((modeCard) => {
      if (!(modeCard instanceof HTMLElement) || modeCard.dataset.initialized === 'true') return;

      const quoteLink = modeCard.querySelector('[data-quote-link]');
      const modePrice = modeCard.querySelector('[data-mode-price]');

      if (!(quoteLink instanceof HTMLAnchorElement) || !(modePrice instanceof HTMLElement)) return;
      modeCard.dataset.initialized = 'true';

      const formationId = modeCard.getAttribute('data-formation-id') || '';
      const priceDistRaw = modeCard.getAttribute('data-price-distanciel');
      const pricePresRaw = modeCard.getAttribute('data-price-presentiel');
      const priceMessage = modeCard.getAttribute('data-price-message') || 'Tarif sur demande';
      const modeInputs = Array.from(modeCard.querySelectorAll('input[type="radio"]'));
      const modeLabels = Array.from(modeCard.querySelectorAll('[data-mode-option]'));

      const modePrices = {
        distanciel: priceDistRaw ? Number(priceDistRaw) : null,
        presentiel: pricePresRaw ? Number(pricePresRaw) : null,
      };

      const formatPrice = (value) => `${new Intl.NumberFormat('fr-FR').format(value)} EUR HT`;
      const getDisplayPrice = (value) =>
        typeof value === 'number' && Number.isFinite(value) && value > 0
          ? formatPrice(value)
          : priceMessage;

      const getSelectedMode = () => {
        const selected = modeInputs.find(
          (input) => input instanceof HTMLInputElement && input.checked
        );
        return selected instanceof HTMLInputElement ? selected.value : '';
      };

      const updateModeStyles = () => {
        modeLabels.forEach((label) => {
          if (!(label instanceof HTMLElement)) return;
          const mode = label.getAttribute('data-mode-option');
          const input = modeCard.querySelector(`input[value="${mode}"]`);
          const isActive = input instanceof HTMLInputElement && input.checked;
          label.classList.toggle('bg-primary', isActive);
          label.classList.toggle('text-white', isActive);
          label.classList.toggle('text-text-muted', !isActive);
        });
      };

      const updateQuoteLink = () => {
        const selectedMode = getSelectedMode();
        if (!selectedMode) {
          updateModeStyles();
          return;
        }

        const selectedPrice = modePrices[selectedMode];
        modePrice.textContent = getDisplayPrice(selectedPrice);

        const params = new URLSearchParams({
          formation: formationId,
          type: selectedMode,
        });
        quoteLink.setAttribute('href', `/demande-devis?${params.toString()}`);
        updateModeStyles();
      };

      modeInputs.forEach((input) => {
        if (input instanceof HTMLInputElement) {
          input.addEventListener('change', updateQuoteLink);
        }
      });

      modeLabels.forEach((label) => {
        if (!(label instanceof HTMLElement)) return;
        label.addEventListener('click', () => {
          const mode = label.getAttribute('data-mode-option');
          const input = modeCard.querySelector(`input[value="${mode}"]`);
          if (input instanceof HTMLInputElement && !input.disabled) {
            input.checked = true;
            updateQuoteLink();
          }
        });
      });

      updateQuoteLink();
      updateModeStyles();
    });
  };

  const initProgramCalendar = () => {
    const calendars = Array.from(document.querySelectorAll('[data-program-calendar]'));

    calendars.forEach((calendar) => {
      if (!(calendar instanceof HTMLElement) || calendar.dataset.initialized === 'true') return;

      const rangeLabel = calendar.querySelector('[data-program-calendar-range]');
      const dayCards = Array.from(calendar.querySelectorAll('[data-program-day]'));

      if (!(rangeLabel instanceof HTMLElement) || !dayCards.length) return;
      calendar.dataset.initialized = 'true';

      const today = new Date();
      const normalizedToday = new Date(today.getFullYear(), today.getMonth(), today.getDate());
      const dayOfWeek = normalizedToday.getDay();
      const daysUntilNextMonday = (8 - dayOfWeek) % 7 || 7;
      const nextMonday = new Date(normalizedToday);
      nextMonday.setDate(normalizedToday.getDate() + daysUntilNextMonday);

      const weekdays = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven'];
      const dayNumberFormatter = new Intl.DateTimeFormat('fr-FR', { day: '2-digit' });
      const fullDateFormatter = new Intl.DateTimeFormat('fr-FR', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
      const shortMonthFormatter = new Intl.DateTimeFormat('fr-FR', { month: 'short' });

      const nextFriday = new Date(nextMonday);
      nextFriday.setDate(nextMonday.getDate() + 4);

      const mondayLabel = fullDateFormatter.format(nextMonday);
      const fridayLabel = fullDateFormatter.format(nextFriday);
      rangeLabel.textContent = `Semaine du ${mondayLabel} au ${fridayLabel}`;

      dayCards.forEach((card, index) => {
        if (!(card instanceof HTMLElement)) return;
        const currentDay = new Date(nextMonday);
        currentDay.setDate(nextMonday.getDate() + index);

        const numberElement = card.querySelector('p:nth-of-type(2)');
        const captionElement = card.querySelector('p:nth-of-type(3)');
        const weekdayElement = card.querySelector('p:nth-of-type(1)');

        if (weekdayElement instanceof HTMLElement) {
          weekdayElement.textContent = weekdays[index];
        }

        if (numberElement instanceof HTMLElement) {
          numberElement.textContent = dayNumberFormatter.format(currentDay);
        }

        if (captionElement instanceof HTMLElement) {
          captionElement.textContent = shortMonthFormatter.format(currentDay).replace('.', '');
        }

        card.setAttribute(
          'aria-label',
          `${weekdays[index]} ${fullDateFormatter.format(currentDay)}`
        );
      });
    });
  };

  initAnchorNav();
  initModeCard();
  initProgramCalendar();
  document.addEventListener('hashchange', initAnchorNav);
  document.addEventListener('astro:page-load', initAnchorNav);
  document.addEventListener('astro:page-load', initModeCard);
  document.addEventListener('astro:page-load', initProgramCalendar);
</script>

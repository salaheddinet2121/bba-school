---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import Cetfication from '@sections/rnq/Cetfication.astro';
import Formation from '@sections/rnq/Formation.astro';
import Rnq from '@sections/rnq/Rnq.astro';
import Testomenial from '@sections/rnq/Testomenial.astro';
import HowItWorks from '@/components/sections/marketing/HowItWorks.astro';

const partnerLogos = [
  { name: 'Carrefour Market', src: '/images/logos/carrefour-market.svg' },
  { name: 'Carrefour', src: '/images/logos/carrefour.svg' },
  { name: 'Crédit Agricole', src: '/images/logos/credit-agricole.svg' },
  { name: 'Intermarché', src: '/images/logos/intermarchee.svg' },
  { name: 'Medicale', src: '/images/logos/medicale.svg' },
];

const steps = [
  { title: 'Choisir sa formation', description: 'Parcourez le catalogue et sélectionnez la technique esthétique qui correspond à votre projet professionnel.', icon: 'lucide:search' },
  { title: 'Valider son accès', description: 'Nous clarifions le format, les options de financement CPF et les modalités avant votre entrée en formation.', icon: 'lucide:settings' },
  { title: 'Se former à distance', description: 'Suivez votre parcours en ligne à votre rythme, avec des modules ciblés et une application terrain immédiate.', icon: 'lucide:monitor-smartphone' },
  { title: 'Obtenir son attestation', description: 'Repartez avec une attestation nominative reconnue et les compétences pour élever votre offre esthétique.', icon: 'lucide:badge-check' },
];
---

<MarketingLayout
  title="BBA School — Formations esthétique à distance | Qualiopi & CPF"
  description="Centre de formation esthétique certifié Qualiopi. Plus de 39 formations à distance : Hydrofacial, Plasma pen, Microblading, Épilation définitive, Massage... Éligibles CPF."
>
  <Hero
    title="Formations esthétique à distance"
    subtitle="Centre certifié Qualiopi. 39 formations professionnelles en esthétique — du soin visage à la pigmentation — disponibles à distance, éligibles CPF, avec kit offert."
    badge="Certifié Qualiopi"
    highlights={[
      'Hydrofacial, Plasma pen, Carbon peel',
      'Éligible CPF — financement simplifié',
      'Kit ou machine offerts selon la formation',
    ]}
    primaryCTA={{ label: 'Voir les formations', href: '/formations' }}
    secondaryCTA={{ label: 'Nous contacter', href: '/contact' }}
    rightImage={{ src: '/images/beauty-collection-hero.png', alt: 'Formations esthétique à distance BBA School' }}
  />

  <LogoCloud
    title="Ils nous font confiance"
    logos={partnerLogos}
    grayscale={true}
    logoSize="lg"
    variant="grid"
    columns={5}
    background="default"
  />

  <Cetfication />
  <Formation />

  <HowItWorks
    title="Comment ça fonctionne"
    subtitle="Un parcours simple, de l'inscription à l'attestation, pensé pour les professionnels de l'esthétique."
    steps={steps}
    variant="horizontal"
    background="default"
  />

  <Rnq />

  <!-- Réclamation -->
  <section class="border-t border-border py-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="max-w-xl">
        <p class="section-kicker mb-3">Médiation & réclamation</p>
        <h2 class="section-title text-2xl text-text">Un accès direct à la médiation et à la réclamation</h2>
        <p class="mt-3 text-sm text-text-muted leading-relaxed">
          Le formulaire de réclamation SODEVA est disponible à tout moment pour transmettre une demande, un signalement ou solliciter une médiation.
        </p>
      </div>
      <a
        href="/rnq/reclamation"
        class="site-button-secondary shrink-0 inline-flex items-center rounded-none px-6 py-3"
      >
        Déposer une réclamation
      </a>
    </div>
  </section>

  <Testomenial />
</MarketingLayout>

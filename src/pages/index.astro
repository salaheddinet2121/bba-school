---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import Cetfication from '@sections/rnq/Cetfication.astro';
import Formation from '@sections/rnq/Formation.astro';
import Rnq from '@sections/rnq/Rnq.astro';
import Testomenial from '@sections/rnq/Testomenial.astro';
import { siteConfig } from '@/config';
import HowItWorks from '@/components/sections/marketing/HowItWorks.astro';

const partnerLogos = [
  { name: 'Carrefour Market', src: '/images/logos/carrefour-market.svg' },
  { name: 'Carrefour', src: '/images/logos/carrefour.svg' },
  { name: 'Crédit Agricole', src: '/images/logos/credit-agricole.svg' },
  { name: 'Intermarché', src: '/images/logos/intermarchee.svg' },
  { name: 'Medicale', src: '/images/logos/medicale.svg' },
];

const steps = [ { title: 'Choisir sa formation', description: 'Parmi toutes nos formations, choisissez celle qui vous correspond le mieux.', icon: 'lucide:search', }, { title: 'Traitement du dossier', description: 'Nous nous occupons pour vous de toutes les démarches administratives.', icon: 'lucide:settings', }, { title: 'Profiter de sa formation', description: 'Nos programmes sont élaborés pour répondre spécifiquement à vos attentes.', icon: 'lucide:monitor-smartphone', }, { title: 'Recevoir son attestation', description: 'Vous recevez votre attestation de formation nominative.', icon: 'lucide:badge-check', }, ];
---

<MarketingLayout
  title={`${siteConfig.name}`}
  description="SODEVA est un organisme de formation certifié Qualiopi. Découvrez notre catalogue, nos informations RNQ et nos modalités de contact."
>
  <Hero
    title="SODEVA, organisme de formation certifié Qualiopi"
    subtitle="Depuis plus de 8 ans, nous accompagnons les professionnels et les entreprises avec des parcours concrets, accessibles et orientés résultats."
    badge="Certifiée Qualiopi"
    primaryCTA={{ label: 'Voir le catalogue', href: '/formations' }}
    secondaryCTA={{ label: 'Contact', href: '/contact' }}
    align="left"
    titleSize="compact"
    visualPosition="right"
    rightImage={{ src: '/images/hero.webp', alt: 'Présentation du centre de formation SODEVA' }}
  />

  <LogoCloud
    title="Ils nous font confiance"
    logos={partnerLogos}
    grayscale={false}
    logoSize="lg"
    variant="grid" columns={5}
    background="accent"
  />

  <Cetfication />
  <Formation />
  <HowItWorks
    title="Votre parcours avec SODEVA"
    subtitle="Une organisation claire pour simplifier chaque étape de votre entrée en formation."
    steps={steps}
    variant="horizontal"
    background="default"
  />
  <Rnq />
  <section class="bg-surface py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-border bg-background p-8 shadow-sm sm:p-10">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.14em] text-primary">
              Réclamation
            </p>
            <h2 class="mt-3 text-3xl font-bold text-text">
              Un accès direct à la médiation et à la réclamation
            </h2>
            <p class="mt-3 text-text-muted">
              Le formulaire de réclamation SODEVA est disponible à tout moment pour transmettre
              une demande, un signalement ou solliciter une médiation.
            </p>
          </div>

          <div class="flex shrink-0">
            <a
              href="/rnq/reclamation"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-primary-dark"
            >
              Déposer une réclamation
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Testomenial />
</MarketingLayout>

---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { siteConfig } from '@/config';
import { documents } from '@/config/documents';

const legalDocuments = [
  { label: 'Certificat Qualiopi', href: documents.certificatQualiopi },
  { label: 'Livret d\'accueil', href: documents.livretAccueil },
  { label: 'Reglement interieur', href: documents.reglementInterieur },
  { label: 'Conditions generales de vente (CGV)', href: documents.cgv },
  { label: 'Engagements deontologiques', href: documents.engagementsDeontologiques },
];
---

<MarketingLayout
  title={`Mentions legales - ${siteConfig.name}`}
  description="Mentions legales et informations de contact SODEVA."
>
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-text">Mentions legales</h1>

      <div class="mt-8 space-y-6 text-text-muted">
        <p><strong class="text-text">Raison sociale:</strong> SODEVA</p>
        <p><strong class="text-text">SIRET:</strong> 940 565 261 00018</p>
        <p>
          <strong class="text-text">Adresse:</strong> 1900 Avenue des Moulins, 34080 Montpellier,
          France
        </p>
        <p><strong class="text-text">Telephone:</strong> 04 65 84 77 00</p>
        <p>
          <strong class="text-text">Email:</strong>
          <a href="mailto:contact@sodeva.fr" class="text-primary hover:underline">contact@sodeva.fr</a>
        </p>
      </div>

      <article class="mt-10 rounded-2xl border border-border bg-background p-6 sm:p-8">
        <h2 class="text-2xl font-semibold text-text">Documents officiels telechargeables</h2>
        <p class="mt-3 text-sm text-text-muted">
          Les documents administratifs et qualitatifs actuellement disponibles sont accessibles ci-dessous.
        </p>

        <ul class="mt-5 space-y-3">
          {
            legalDocuments.map((item) => (
              <li>
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-primary hover:underline"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </section>
</MarketingLayout>

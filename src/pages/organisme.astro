---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { siteConfig } from '@/config';
---

<MarketingLayout
  title={`L'organisme - ${siteConfig.name}`}
  description="Presentation de l'organisme SODEVA."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-text">L'organisme</h1>
      <p class="mt-6 text-text-muted max-w-3xl">
        SODEVA est un organisme de formation et CFA qui accompagne les acteurs de la pedagogie,
        les professionnels et les structures dans le developpement de competences directement mobilisables.
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <article class="rounded-xl border border-border p-6 bg-surface">
          <h2 class="text-xl font-semibold text-text">Notre mission</h2>
          <p class="mt-3 text-sm text-text-muted">
            Proposer des parcours utiles, accessibles et alignes avec les realites operationnelles des apprenants.
          </p>
        </article>
        <article class="rounded-xl border border-border p-6 bg-surface">
          <h2 class="text-xl font-semibold text-text">Qualite & certification</h2>
          <p class="mt-3 text-sm text-text-muted">
            Notre demarche qualite est structuree autour de l amelioration continue et de la certification Qualiopi.
          </p>
          <a
            class="inline-block mt-4 text-primary hover:underline"
            href="https://api-sodeva.fr/certificat_qualiopi_sodeva.pdf"
            target="_blank"
            rel="noopener noreferrer"
          >
            Voir le certificat Qualiopi
          </a>
        </article>
      </div>
    </div>
  </section>
</MarketingLayout>

---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import ReclamationForm from '@/components/forms/ReclamationForm.astro';
import { siteConfig } from '@/config';
---

<MarketingLayout
  title={`Formulaire de réclamation - ${siteConfig.name}`}
  description="Déposez une réclamation auprès de SODEVA via le formulaire dédié."
>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-text">Formulaire de réclamation</h1>
      <p class="mt-4 text-text-muted">
        Utilisez ce formulaire pour nous transmettre une réclamation. Chaque demande est tracée
        et traitée dans les meilleurs délais.
      </p>

      <div class="mt-8 rounded-2xl border border-border bg-surface p-6 sm:p-8">
        <ReclamationForm />
      </div>
    </div>
  </section>
</MarketingLayout>

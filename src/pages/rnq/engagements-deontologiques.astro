---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { siteConfig } from '@/config';
---

<MarketingLayout
  title={`Engagements deontologiques - ${siteConfig.name}`}
  description="Engagements deontologiques de SODEVA."
>
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-text">Engagements deontologiques</h1>
      <p class="mt-4 text-text-muted">Cette page est prete. Vous pourrez ajouter le contenu final ici.</p>

      <article class="mt-8 rounded-2xl border border-dashed border-border bg-surface p-8">
        <h2 class="text-xl font-semibold text-text">Contenu provisoire</h2>
        <p class="mt-3 text-sm text-text-muted">
          Inserer ici vos engagements deontologiques et principes de conduite.
        </p>
      </article>
    </div>
  </section>
</MarketingLayout>

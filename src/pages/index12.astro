---
import MarketingLayout from '@/layouts/MarketingLayout.astro';

const organismeName = "Nom de l’Organisme";
const title = `${organismeName} - Accès suspendu`;
const description = "Accès suspendu : paiement non reçu.";
---

<MarketingLayout title={title} description={description}>
  <section style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 4rem 1.5rem;">
    <div style="max-width: 720px; width: 100%; border: 1px solid #eee; border-radius: 14px; padding: 2rem; background: #fff; box-shadow: 0 2px 10px #0001; text-align: center;">
      
      <h1 style="font-size: 2rem; font-weight: 800; margin: 0 0 0.75rem;">
        Accès suspendu
      </h1>

      <p style="font-size: 1.1rem; margin: 0 0 1.25rem; color: #444;">
        Ce client n’a pas payé.
      </p>

      <p style="margin: 0 0 1.5rem; color: #666; line-height: 1.6;">
        Le site est temporairement désactivé jusqu’à régularisation du paiement.
        Pour réactiver l’accès, merci de contacter l’administrateur.
      </p>

      <a
        href="/contact"
        style="display: inline-block; padding: 0.75rem 1.25rem; border-radius: 10px; text-decoration: none; border: 1px solid #ddd; background: #fafbfc; font-weight: 600;"
      >
        Contacter
      </a>
    </div>
  </section>
</MarketingLayout>

---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';
import { documents } from '@/config/documents';

const rnqPages = [
  {
    title: 'Médiation et réclamation',
    icon: 'lucide:message-square-warning',
    href: '/rnq/reclamation',
    description:
      'Déposez votre réclamation via un formulaire dédié. Votre demande est enregistrée et traitée dans les meilleurs délais.',
  },
  {
    title: 'Livret d\'accueil',
    icon: 'lucide:notebook-pen',
    href: '/rnq/livret-accueil',
    downloadHref: documents.livretAccueil,
    description:
      'Consultez les informations essentielles sur le déroulé des formations, les règles et les modalités d\'accompagnement.',
  },
  {
    title: 'Règlement intérieur',
    icon: 'lucide:scale',
    href: '/rnq/reglement-interieur',
    downloadHref: documents.reglementInterieur,
    description: 'Règles applicables pendant le parcours de formation, disponibles au format PDF.',
  },
  {
    title: 'CGV',
    icon: 'lucide:file-text',
    href: '/rnq/cgv',
    description: 'Consultez les conditions générales de vente SODEVA en version web, structurées par article.',
  },
  {
    title: 'Engagements déontologiques',
    icon: 'lucide:badge-check',
    href: '/rnq/engagements-deontologiques',
    downloadHref: documents.engagementsDeontologiques,
    description: 'Principes déontologiques de SODEVA, disponibles au format PDF.',
  },
];
---

<MarketingLayout
  title={`Informations pratiques - ${siteConfig.name}`}
  description="Informations RNQ et documents utiles: réclamation, livret d'accueil, règlement intérieur, CGV et engagements déontologiques."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-text">Informations pratiques</h1>
      <p class="mt-4 text-text-muted max-w-3xl">
        Cette page centralise les informations et documents RNQ/Qualiopi accessibles à vos équipes et apprenants.
      </p>

      <article id="resultats-indicateurs" class="mt-10 rounded-2xl border border-border bg-background p-3 sm:p-4">
        <details class="group" open>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-xl px-3 py-3 transition-colors hover:bg-surface">
            <div class="flex items-start gap-3">
              <div class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                <Icon name="lucide:chart-no-axes-combined" class="h-5 w-5" />
              </div>
              <div>
                <h2 class="text-2xl font-semibold text-text">Résultats & indicateurs</h2>
                <p class="mt-1 text-sm text-text-muted">
                  Indicateurs de résultats adaptés à la nature des prestations mises en oeuvre et des publics accueillis.
                </p>
              </div>
            </div>
            <Icon
              name="lucide:chevron-down"
              class="h-5 w-5 shrink-0 text-text-muted transition-transform duration-300 group-open:rotate-180"
            />
          </summary>

          <div class="px-3 pb-3 pt-2">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              <div class="rounded-xl border border-border bg-background p-4">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-text-muted">
                  Taux de réussite
                </p>
                <p class="mt-2 text-base font-semibold text-primary">20 apprenants</p>
              </div>
              <div class="rounded-xl border border-border bg-background p-4">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-text-muted">Nombre de stagiaires formés</p>
                <p class="mt-2 text-base font-semibold text-primary">20</p>
              </div>
              <div class="rounded-xl border border-border bg-background p-4">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-text-muted">Taux de satisfaction</p>
                <p class="mt-2 text-base font-semibold text-primary">100%</p>
              </div>
              <div class="rounded-xl border border-border bg-background p-4">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-text-muted">
                  Taux d'abandon
                </p>
                <p class="mt-2 text-base font-semibold text-primary">0</p>
              </div>
            </div>
          </div>
        </details>
      </article>

      <div class="mt-8 grid gap-6">
        {
          rnqPages.map((item, index) => (
            <a
              href={item.downloadHref ?? item.href}
              download={item.downloadHref ? '' : undefined}
              class="group relative overflow-hidden rounded-2xl border border-border bg-background p-6 transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/10 animate-in"
              style={`animation-delay: ${index * 70}ms`}
            >
              <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 card-glow"></div>
              <div class="relative flex items-start gap-4">
                <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-all duration-300 group-hover:scale-105 group-hover:bg-primary group-hover:text-white">
                  <Icon name={item.icon} class="h-5 w-5" />
                </div>
                <div>
                  <h2 class="text-2xl font-semibold text-text">{item.title}</h2>
                  <p class="mt-3 text-sm text-text-muted">{item.description}</p>
                  {
                    item.downloadHref && (
                      <p class="mt-3">
                        <span class="inline-flex items-center gap-2 text-sm font-medium text-primary">
                          <Icon name="lucide:download" class="h-4 w-4" />
                          Télécharger le PDF
                        </span>
                      </p>
                    )
                  }
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <div
        id="accessibilite"
        class="mt-6 overflow-hidden rounded-2xl border border-border bg-background shadow-sm"
      >
        <div class="border-b border-border bg-surface/70 px-6 py-5 sm:px-8">
          <div class="flex items-start gap-4">
            <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
              <Icon name="lucide:accessibility" class="h-5 w-5" />
            </div>
            <div>
              <h2 class="text-2xl font-semibold text-text">Accessibilité handicap</h2>
              <p class="mt-2 text-sm text-text-muted">
                Nous étudions les besoins d'aménagement avant l'entrée en formation et pendant le
                parcours si nécessaire.
              </p>
            </div>
          </div>
        </div>

        <div class="grid gap-4 px-6 py-6 sm:px-8 md:grid-cols-[1.4fr_1fr]">
          <div class="rounded-xl border border-primary/15 bg-primary/5 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.12em] text-primary">
              Accueil des publics
            </p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="inline-flex items-center rounded-full bg-background px-3 py-1 text-sm font-medium text-text shadow-sm ring-1 ring-border">
                PMR: oui
              </span>
              <span class="inline-flex items-center rounded-full bg-background px-3 py-1 text-sm font-medium text-text shadow-sm ring-1 ring-border">
                PSH: oui
              </span>
            </div>
            <p class="mt-4 text-sm leading-relaxed text-text-muted">
              Merci de nous contacter pour prévoir un aménagement si possible.
            </p>
          </div>

          <div class="rounded-xl border border-border bg-background p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.12em] text-primary">
              Référent handicap
            </p>
            <p class="mt-3 text-base font-semibold text-text">Amine Es Salah</p>
            <a
              href="mailto:contact@sodeva.fr"
              class="mt-2 inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline"
            >
              <Icon name="lucide:mail" class="h-4 w-4" />
              contact@sodeva.fr
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .animate-in {
    animation: fade-slide-up 0.6s ease-out both;
  }

  .card-glow {
    background: linear-gradient(120deg, transparent 0%, rgb(99 102 241 / 0.06) 45%, transparent 100%);
  }

  @keyframes fade-slide-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

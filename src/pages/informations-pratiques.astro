---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';

const rnqPages = [
  {
    title: 'Formulaire de reclamation',
    icon: 'lucide:message-square-warning',
    href: '/rnq/reclamation',
    description:
      'Deposez votre reclamation via un formulaire dedie. Votre demande est enregistree et traitee dans les meilleurs delais.',
  },
  {
    title: 'Livret d accueil',
    icon: 'lucide:notebook-pen',
    href: '/rnq/livret-accueil',
    description:
      'Consultez les informations essentielles sur le deroule des formations, les regles et les modalites d accompagnement.',
  },
  {
    title: 'Reglement interieur',
    icon: 'lucide:scale',
    href: '/rnq/reglement-interieur',
    description: 'Regles applicables pendant le parcours de formation. Page prete avec espace de contenu a completer.',
  },
  {
    title: 'CGV',
    icon: 'lucide:file-text',
    href: '/rnq/cgv',
    description: 'Conditions generales de vente. Page prete avec bloc de contenu a renseigner ulterieurement.',
  },
  {
    title: 'Engagements deontologiques',
    icon: 'lucide:badge-check',
    href: '/rnq/engagements-deontologiques',
    description: 'Principes deontologiques de SODEVA. Page prete avec zone de contenu a remplir.',
  },
];
---

<MarketingLayout
  title={`Informations pratiques - ${siteConfig.name}`}
  description="Informations RNQ et documents utiles: reclamation, livret d accueil, reglement interieur, CGV et engagements deontologiques."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-text">Informations pratiques</h1>
      <p class="mt-4 text-text-muted max-w-3xl">
        Cette page centralise les informations et documents RNQ/Qualiopi accessibles a vos equipes et apprenants.
      </p>

      <article id="resultats-indicateurs" class="mt-10 rounded-2xl border border-border bg-background p-3 sm:p-4">
        <details class="group" open>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-xl px-3 py-3 transition-colors hover:bg-surface">
            <div class="flex items-start gap-3">
              <div class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                <Icon name="lucide:chart-no-axes-combined" class="h-5 w-5" />
              </div>
              <div>
                <h2 class="text-2xl font-semibold text-text">Resultats & indicateurs</h2>
                <p class="mt-1 text-sm text-text-muted">
                  Indicateurs de resultats adaptes a la nature des prestations mises en oeuvre et des publics accueillis.
                </p>
              </div>
            </div>
            <Icon
              name="lucide:chevron-down"
              class="h-5 w-5 shrink-0 text-text-muted transition-transform duration-300 group-open:rotate-180"
            />
          </summary>

          <div class="px-3 pb-3 pt-2">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              <div class="rounded-xl border border-border bg-background p-4">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-text-muted">KPI</p>
                <p class="mt-2 text-base font-semibold text-black">Satisfaction et competences</p>
              </div>
              <div class="rounded-xl border border-border bg-background p-4">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-text-muted">Nombre de stagiaires formes</p>
                <p class="mt-2 text-base font-semibold text-primary">XX</p>
              </div>
              <div class="rounded-xl border border-border bg-background p-4">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-text-muted">Taux d abandon</p>
                <p class="mt-2 text-base font-semibold text-primary">0%</p>
              </div>
              <div class="rounded-xl border border-border bg-background p-4">
                <p class="text-xs font-medium uppercase tracking-[0.1em] text-text-muted">Taux de satisfaction</p>
                <p class="mt-2 text-base font-semibold text-primary">XX%</p>
              </div>
            </div>
          </div>
        </details>
      </article>

      <div class="mt-8 grid gap-6">
        {
          rnqPages.map((item, index) => (
            <a
              href={item.href}
              class="group relative overflow-hidden rounded-2xl border border-border bg-background p-6 transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/10 animate-in"
              style={`animation-delay: ${index * 70}ms`}
            >
              <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 card-glow"></div>
              <div class="relative flex items-start gap-4">
                <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-all duration-300 group-hover:scale-105 group-hover:bg-primary group-hover:text-white">
                  <Icon name={item.icon} class="h-5 w-5" />
                </div>
                <div>
                  <h2 class="text-2xl font-semibold text-text">{item.title}</h2>
                  <p class="mt-3 text-sm text-text-muted">{item.description}</p>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <div id="accessibilite" class="mt-6 rounded-2xl border border-border bg-background p-6 sm:p-8">
        <h2 class="text-2xl font-semibold text-text">Accessibilite handicap</h2>
        <p class="mt-3 text-sm text-text-muted">
          SODEVA prend en compte les situations de handicap. Les besoins d adaptation sont etudies
          avant et pendant le parcours, avec un accompagnement dedie.
        </p>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .animate-in {
    animation: fade-slide-up 0.6s ease-out both;
  }

  .card-glow {
    background: linear-gradient(120deg, transparent 0%, rgb(99 102 241 / 0.06) 45%, transparent 100%);
  }

  @keyframes fade-slide-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

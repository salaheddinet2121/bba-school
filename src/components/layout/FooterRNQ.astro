---
/**
 * Footer - Site-wide footer with navigation and social links
 *
 * @description
 * A comprehensive footer with 5-column navigation layout:
 * Brand, Product, Solutions, Resources, Company.
 * Navigation items are automatically filtered based on feature flags.
 *
 * @example
 * ```astro
 * <Footer />
 * ```
 */
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';
import type { FeatureFlags, NavigationItem } from '@/lib/types';

const { features, social, contact, navigation } = siteConfig;
const { footer } = navigation;
const currentYear = new Date().getFullYear();

// Helper to filter items by feature flag
const filterByFeature = (items: NavigationItem[]) =>
  items.filter((item) => !item.feature || features[item.feature as keyof FeatureFlags]);

// Filter all navigation sections
const productLinks = filterByFeature(footer.product);
const solutionsLinks = filterByFeature(footer.solutions);
const resourcesLinks = filterByFeature(footer.resources);
const companyLinks = filterByFeature(footer.company);
const legalLinks = filterByFeature(footer.legal);
---

<footer class="footer-shell border-t border-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Links Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="col-span-2 sm:col-span-3 lg:col-span-2 mb-4 lg:mb-0">
        <a href="/" class="inline-flex items-center gap-2 text-lg font-semibold">
          {
            siteConfig.logo ? (
              <img src={siteConfig.logo} alt={siteConfig.name} class="h-12 w-auto" />
            ) : (
              siteConfig.name
            )
          }
        </a>
        <!-- Qualiopi Certification Badge/Text -->
        <p class="footer-muted mt-3 max-w-xs text-sm">
          {siteConfig.description}
        </p>
        <div class="footer-muted mt-4 space-y-1 text-sm">
          {
            contact.email && (
              <a href={`mailto:${contact.email}`} class="footer-link block transition-colors">
                {contact.email}
              </a>
            )
          }
          {
            contact.address && (
              <p>
                {contact.address.city}, {contact.address.state}, {contact.address.country}
              </p>
            )
          }
        </div>
        <div class="mt-6">
          <a
            href="/rnq/reclamation"
            class="footer-cta inline-flex items-center gap-2 rounded-full px-4 py-2.5 text-sm font-semibold transition-colors"
          >
            <Icon name="lucide:message-square-warning" class="h-4 w-4" />
            Déposer une réclamation
          </a>
        </div>
        <div class="flex items-center gap-4 mt-4">
          {
            social.twitter && (
              <a
                href={social.twitter}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Twitter"
                class="footer-link transition-colors"
              >
                <Icon name="lucide:twitter" class="w-5 h-5" />
              </a>
            )
          }
          {
            social.github && (
              <a
                href={social.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="footer-link transition-colors"
              >
                <Icon name="lucide:github" class="w-5 h-5" />
              </a>
            )
          }
          {
            social.discord && (
              <a
                href={social.discord}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Discord"
                class="footer-link transition-colors"
              >
                <Icon name="simple-icons:discord" class="w-5 h-5" />
              </a>
            )
          }
        </div>
      </div>

      <!-- Product Column -->
      {
        productLinks.length > 0 && (
          <div>
            <h3 class="footer-heading mb-4 text-sm font-semibold">Collections</h3>
            <ul class="space-y-3">
              {productLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="footer-link text-sm transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Solutions Column -->
      {
        solutionsLinks.length > 0 && (
          <div>
            <h3 class="footer-heading mb-4 text-sm font-semibold">RNQ</h3>
            <ul class="space-y-3">
              {solutionsLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="footer-link text-sm transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Resources Column -->
      {
        resourcesLinks.length > 0 && (
          <div>
            <h3 class="footer-heading mb-4 text-sm font-semibold">Qualiopi</h3>
            <ul class="space-y-3">
              {resourcesLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="footer-link text-sm transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Company Column -->
      {
        companyLinks.length > 0 && (
          <div>
            <h3 class="footer-heading mb-4 text-sm font-semibold">Maison</h3>
            <ul class="space-y-3">
              {companyLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="footer-link text-sm transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    <!-- Certification / Logos Row -->
    <div class="mt-14 grid grid-cols-1 gap-6 border-t border-white/10 pt-10 md:grid-cols-2 md:items-stretch">
      <!-- <div class="flex items-center justify-center md:justify-start">
       
                <img
          src="/images/centreagree.webp"
          alt="Certification Centre Agree"
          class="mx-auto h-20 w-auto object-contain"/>
      </div> -->

      <div class="rounded-2xl border border-white/8 bg-white/[0.03] px-6 py-8 text-center">
        <img
          src="/images/qualiopi.webp"
          alt="Certification Qualiopi"
          class="mx-auto h-24 w-auto object-contain"
        />
        <p class="footer-muted mx-auto mt-4 max-w-md text-sm leading-relaxed">
          La certification qualité a été délivrée au titre des catégories d'actions de formation.
        </p>
      </div>

      <div class="flex items-center justify-center rounded-2xl border border-white/8 bg-white/[0.03] px-6 py-8 md:justify-center">
        <img
          src="/images/cpf.webp"
          alt="Certification CPF"
          class="mx-auto h-24 w-auto object-contain"
        />
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-divider mt-12 border-t pt-8">
      <div
        class="flex flex-col items-center md:flex-row md:justify-between gap-4 text-center md:text-left"
      >
        <div class="space-y-1">
          <p class="footer-muted text-sm">
            &copy; {currentYear}
            {siteConfig.name}. Tous droits réservés.
          </p>
        </div>
        <div class="flex flex-wrap items-center justify-center gap-6 md:justify-end">
          {
            legalLinks.map((link) => (
              <a href={link.href} class="footer-link text-sm transition-colors">
                {link.label}
              </a>
            ))
          }
          <a href="#cookies" class="text-sm text-text-muted hover:text-text transition-colors">
            Gestion des cookies
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

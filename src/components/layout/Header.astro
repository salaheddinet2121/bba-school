---
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';
import type { FeatureFlags } from '@/lib/types';

const { features, navigation } = siteConfig;
const { header: headerNav } = navigation;

const mainNavItems = headerNav.main.filter(
  (item) => !item.feature || features[item.feature as keyof FeatureFlags]
);

const primaryCTA = headerNav.cta.find((cta) => cta.variant === 'primary');
---

<header id="site-header" class="sticky top-0 z-50 border-b border-border/90 bg-white/95 backdrop-blur">
  <!-- Logo row -->
  <div class="flex items-center justify-between px-6 py-3 md:px-10 md:py-5">
    <a href="/" class="flex items-center shrink-0">
      {
        siteConfig.logo ? (
          <img src={siteConfig.logo} alt={siteConfig.name} class="h-14 w-auto md:h-18" />
        ) : (
          <span class="font-display text-2xl tracking-wide">{siteConfig.name}</span>
        )
      }
    </a>

    <nav
      class="hidden md:flex items-center justify-center gap-10 px-10 py-3 flex-1"
      aria-label="Navigation principale"
    >
      {
        mainNavItems.map((item) => (
          <a
            href={item.href}
            class="site-nav-link py-1 text-sm transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4 shrink-0">
      {
        primaryCTA && (
          <a
            href={primaryCTA.href}
            class="hidden md:inline-flex site-button-primary items-center rounded-none px-5 py-2.5 text-[0.78rem]"
          >
            {primaryCTA.label}
          </a>
        )
      }

      <button
        id="mobile-menu-button"
        type="button"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="flex items-center md:hidden text-text-muted"
      >
        <Icon name="lucide:menu" id="menu-icon-open" class="w-5 h-5" aria-hidden="true" />
        <Icon name="lucide:x" id="menu-icon-close" class="hidden w-5 h-5" aria-hidden="true" />
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menu mobile"
>
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/40"></div>
  <nav
    id="mobile-menu-panel"
    class="absolute left-0 right-0 bg-white shadow-lg"
    aria-label="Navigation mobile"
  >
    <div class="divide-y divide-border">
      {
        mainNavItems.map((item) => (
          <a
            href={item.href}
            class="block px-6 py-4 text-sm text-text transition-colors hover:bg-surface"
          >
            {item.label}
          </a>
        ))
      }
      {
        primaryCTA && (
          <div class="p-4">
            <a
              href={primaryCTA.href}
              class="site-button-primary block w-full rounded-none px-4 py-3 text-center text-xs"
            >
              {primaryCTA.label}
            </a>
          </div>
        )
      }
    </div>
  </nav>
</div>

<script>
  const header = document.getElementById('site-header');
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  function updateMenuPosition() {
    if (header && mobileMenuPanel) {
      const headerRect = header.getBoundingClientRect();
      mobileMenuPanel.style.top = `${headerRect.bottom}px`;
    }
  }

  function openMobileMenu() {
    updateMenuPosition();
    mobileMenu?.classList.remove('hidden');
    mobileMenuButton?.setAttribute('aria-expanded', 'true');
    menuIconOpen?.classList.add('hidden');
    menuIconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenuButton?.setAttribute('aria-expanded', 'false');
    menuIconOpen?.classList.remove('hidden');
    menuIconClose?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  mobileMenuButton?.addEventListener('click', () => {
    const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
    isExpanded ? closeMobileMenu() : openMobileMenu();
  });

  mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenuButton?.getAttribute('aria-expanded') === 'true') {
      closeMobileMenu();
      mobileMenuButton?.focus();
    }
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });
</script>

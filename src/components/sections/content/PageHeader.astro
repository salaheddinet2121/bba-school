---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  size?: 'default' | 'large';
  maxWidth?: 'sm' | 'md' | 'lg' | 'full';
  background?: 'default' | 'muted' | 'accent';
}

const {
  title,
  subtitle,
  align = 'left',
  size = 'default',
  background = 'default',
} = Astro.props;

const bgClass = {
  default: 'bg-white',
  muted: 'bg-surface',
  accent: 'bg-surface',
}[background];

const alignClass = align === 'center' ? 'text-center' : 'text-left';
const titleSizeClass = size === 'large' ? 'text-5xl sm:text-6xl' : 'text-4xl sm:text-5xl';
---

<section class:list={['border-b border-border py-14 md:py-20', bgClass]}>
  <div class="max-w-7xl mx-auto px-6 sm:px-10">
    <div class:list={[alignClass]}>
      <h1 class:list={['section-title text-text leading-tight', titleSizeClass]}>
        {title}
      </h1>
      {subtitle && (
        <p class="mt-5 text-base text-text-muted leading-relaxed max-w-2xl">
          {subtitle}
        </p>
      )}
      <slot />
    </div>
  </div>
</section>

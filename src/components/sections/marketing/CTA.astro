---
interface Props {
  title: string;
  description: string;
  action: { label: string; href: string };
  secondaryAction?: { label: string; href: string };
  background?: 'default' | 'muted' | 'accent';
}

const { title, description, action, secondaryAction } = Astro.props;
---

<section class="bg-surface border-t border-border py-24">
  <div class="max-w-5xl mx-auto px-6 sm:px-10 text-center">
    <p class="section-kicker mb-5">Accompagnement</p>
    <h2 class="section-title text-4xl sm:text-5xl text-text max-w-2xl mx-auto leading-tight">
      {title}
    </h2>
    <p class="mt-5 text-base text-text-muted max-w-xl mx-auto leading-relaxed">
      {description}
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        href={action.href}
        class="site-button-primary inline-flex items-center rounded-none px-8 py-3.5"
      >
        {action.label}
      </a>
      {secondaryAction && (
        <a
          href={secondaryAction.href}
          class="site-button-secondary inline-flex items-center rounded-none px-8 py-3.5"
        >
          {secondaryAction.label}
        </a>
      )}
    </div>
  </div>
</section>

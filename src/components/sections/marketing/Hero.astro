---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  subtitle: string;
  primaryCTA: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  badge?: string;
  highlights?: string[];
  rightImage?: { src: string; alt: string };
  /** unused legacy props kept for compatibility */
  backgroundType?: string;
  background?: string;
  gradient?: string;
  backgroundImage?: string;
  backgroundVideo?: string;
  backgroundVideoPoster?: string;
  overlay?: boolean;
  overlayOpacity?: number;
  textColor?: string;
  minHeight?: string;
  align?: string;
  rightPlaceholderLabel?: string;
  titleSize?: string;
  visualPosition?: string;
}

const {
  title,
  subtitle,
  primaryCTA,
  secondaryCTA,
  badge,
  highlights = [],
  rightImage,
} = Astro.props;
---

<section class="border-b border-border bg-white py-18 md:py-24">
  <div class="max-w-6xl mx-auto px-6 sm:px-10">
    {
      rightImage ? (
        <div class="grid items-center gap-14 md:grid-cols-[0.95fr_1.05fr]">
          <div>
            {badge && (
              <p class="section-kicker mb-5">{badge}</p>
            )}
            <h1 class="hero-title text-5xl sm:text-6xl leading-[1.05] text-text">
              {title}
            </h1>
            <p class="mt-6 max-w-lg text-base leading-relaxed text-text-muted">
              {subtitle}
            </p>
            {highlights.length > 0 && (
              <ul class="mt-8 space-y-4">
                {highlights.map((item) => (
                  <li class="flex items-center gap-3 text-sm text-text-muted">
                    <span class="block h-px w-5 bg-border shrink-0" />
                    {item}
                  </li>
                ))}
              </ul>
            )}
            <div class="mt-10 flex flex-wrap gap-3">
              <a
                href={primaryCTA.href}
                class="site-button-primary inline-flex items-center gap-2 rounded-none px-6 py-3"
              >
                {primaryCTA.label}
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </a>
              {secondaryCTA && (
                <a
                  href={secondaryCTA.href}
                  class="site-button-secondary inline-flex items-center rounded-none px-6 py-3"
                >
                  {secondaryCTA.label}
                </a>
              )}
            </div>
          </div>
          <div>
            <img
              src={rightImage.src}
              alt={rightImage.alt}
              class="soft-panel w-full object-cover p-4"
              loading="eager"
            />
          </div>
        </div>
      ) : (
        <div class="text-center max-w-3xl mx-auto">
          {badge && (
            <p class="section-kicker mb-5">{badge}</p>
          )}
          <h1 class="hero-title text-5xl sm:text-6xl md:text-7xl leading-[1.05] text-text">
            {title}
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-text-muted">
            {subtitle}
          </p>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
            <a
              href={primaryCTA.href}
              class="site-button-primary inline-flex items-center gap-2 rounded-none px-7 py-3.5"
            >
              {primaryCTA.label}
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
            {secondaryCTA && (
              <a
                href={secondaryCTA.href}
                class="site-button-secondary inline-flex items-center rounded-none px-7 py-3.5"
              >
                {secondaryCTA.label}
              </a>
            )}
          </div>
        </div>
      )
    }
  </div>
</section>

---
import { Icon } from 'astro-icon/components';

const kpiItems = [
  {
    title: 'Taux de réussite',
    value: '20 apprenants',
    icon: 'lucide:graduation-cap',
    cardClass: 'border-border bg-background',
    iconClass: 'bg-primary/10 text-primary',
    valueClass: 'text-primary',
  },
  {
    title: 'Nombre de stagiaires formés',
    value: '20',
    icon: 'lucide:users',
    cardClass: 'border-border bg-background',
    iconClass: 'bg-primary/10 text-primary',
    valueClass: 'text-primary',
  },
  {
    title: 'Taux de satisfaction',
    value: '100%',
    icon: 'lucide:smile',
    cardClass: 'border-border bg-background',
    iconClass: 'bg-primary/10 text-primary',
    valueClass: 'text-primary',
  },
  {
    title: "Taux d'abandon",
    value: '0',
    icon: 'lucide:user-x',
    cardClass: 'border-border bg-background',
    iconClass: 'bg-primary/10 text-primary',
    valueClass: 'text-primary',
  },
];

const rnqLinks = [
  {
    title: 'Résultats & indicateurs',
    description: 'Accédez aux informations sur la satisfaction et le suivi des parcours.',
    href: '/informations-pratiques#resultats-indicateurs',
    icon: 'lucide:line-chart',
  },
  {
    title: 'Livret d\'accueil',
    description: 'Retrouvez le cadre d\'accueil, les modalités et le déroulé des formations.',
    href: '/rnq/livret-accueil',
    icon: 'lucide:notebook-pen',
  },
  {
    title: 'Médiation et réclamation',
    description: 'Accédez au formulaire de réclamation et aux modalités de traitement de votre demande.',
    href: '/rnq/reclamation',
    icon: 'lucide:message-square-warning',
  },
  {
    title: 'Engagements déontologiques',
    description: 'Consultez les principes et engagements déontologiques de l\'organisme.',
    href: '/rnq/engagements-deontologiques',
    icon: 'lucide:badge-check',
  },
];
---

<section class="py-section bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.14em] text-primary">RNQ</p>
    <h2 class="mt-3 text-3xl font-bold text-text">Liens rapides RNQ</h2>
    <p class="mt-3 max-w-3xl text-text-muted">
      Toutes les informations attendues dans le cadre de la certification sont centralisées pour un accès simple et transparent.
    </p>

    <article class="mt-8 rounded-2xl border border-border bg-background p-6 sm:p-8">
      <div class="flex items-start gap-3">
        <div class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
          <Icon name="lucide:chart-no-axes-combined" class="h-5 w-5" />
        </div>
        <div>
          <h3 class="text-2xl font-semibold text-text">Résultats & indicateurs</h3>
          <p class="mt-2 text-sm text-text-muted">
            Indicateurs de résultats adaptés à la nature des prestations mises en oeuvre et des
            publics accueillis.
          </p>
        </div>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          kpiItems.map((item) => (
            <div class:list={['rounded-xl border p-4', item.cardClass]}>
              <div class:list={['inline-flex h-8 w-8 items-center justify-center rounded-md', item.iconClass]}>
                <Icon name={item.icon} class="h-4 w-4" />
              </div>
              <p class="mt-3 text-xs font-medium uppercase tracking-[0.1em] text-text-muted">{item.title}</p>
              <p class:list={['mt-1 text-lg font-semibold', item.valueClass]}>{item.value}</p>
            </div>
          ))
        }
      </div>
    </article>

    <article class="mt-6 overflow-hidden rounded-2xl border border-border bg-background shadow-sm">
      <div class="border-b border-border bg-surface/70 px-6 py-5 sm:px-8">
        <div class="flex items-start gap-4">
          <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Icon name="lucide:accessibility" class="h-5 w-5" />
          </div>
          <div>
            <h3 class="text-2xl font-semibold text-text">Accessibilité handicap</h3>
            <p class="mt-2 text-sm text-text-muted">
              Nous étudions les besoins d'aménagement avant l'entrée en formation et pendant le
              parcours si nécessaire.
            </p>
          </div>
        </div>
      </div>

      <div class="grid gap-4 px-6 py-6 sm:px-8 md:grid-cols-[1.4fr_1fr]">
        <div class="rounded-xl border border-primary/15 bg-primary/5 p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-primary">
            Accueil des publics
          </p>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="inline-flex items-center rounded-full bg-background px-3 py-1 text-sm font-medium text-text shadow-sm ring-1 ring-border">
              PMR: oui
            </span>
            <span class="inline-flex items-center rounded-full bg-background px-3 py-1 text-sm font-medium text-text shadow-sm ring-1 ring-border">
              PSH: oui
            </span>
          </div>
          <p class="mt-4 text-sm leading-relaxed text-text-muted">
            Merci de nous contacter pour prévoir un aménagement si possible.
          </p>
        </div>

        <div class="rounded-xl border border-border bg-background p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-primary">
            Référent handicap
          </p>
          <p class="mt-3 text-base font-semibold text-text">Amine Es Salah</p>
          <a
            href="mailto:contact@sodeva.fr"
            class="mt-2 inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline"
          >
            <Icon name="lucide:mail" class="h-4 w-4" />
            contact@sodeva.fr
          </a>
        </div>
      </div>
    </article>

    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {
        rnqLinks.map((item) => (
          <a
            href={item.href}
            class="group rounded-2xl border border-border bg-background p-5 transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-md"
          >
            <div class="flex items-start gap-4">
              <div class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors duration-300 group-hover:bg-primary group-hover:text-white">
                <Icon name={item.icon} class="h-5 w-5" />
              </div>
              <div>
                <h3 class="text-lg font-semibold text-text">{item.title}</h3>
                <p class="mt-1 text-sm text-text-muted">{item.description}</p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

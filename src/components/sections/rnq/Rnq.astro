---
import { Icon } from 'astro-icon/components';

const kpiItems = [
  { title: 'Apprenants formés', value: '20', icon: 'lucide:users' },
  { title: 'Taux de satisfaction', value: '100%', icon: 'lucide:smile' },
  { title: "Taux d'abandon", value: '0%', icon: 'lucide:trending-up' },
  { title: 'Taux de réussite', value: '100%', icon: 'lucide:graduation-cap' },
];

const rnqLinks = [
  { title: "Livret d'accueil", description: "Cadre d'accueil, modalités et déroulé des formations.", href: '/rnq/livret-accueil', icon: 'lucide:notebook-pen' },
  { title: 'Médiation & réclamation', description: 'Formulaire de réclamation et modalités de traitement.', href: '/rnq/reclamation', icon: 'lucide:message-square-warning' },
  { title: 'Engagements déontologiques', description: 'Principes et engagements de notre organisme.', href: '/rnq/engagements-deontologiques', icon: 'lucide:badge-check' },
  { title: 'Résultats & indicateurs', description: 'Satisfaction et suivi des parcours de formation.', href: '/informations-pratiques#resultats-indicateurs', icon: 'lucide:line-chart' },
];
---

<section class="border-t border-border bg-surface py-24">
  <div class="mx-auto max-w-7xl px-6 sm:px-10">
    <div class="mb-12 max-w-2xl">
      <p class="section-kicker mb-4">RNQ — Qualité</p>
      <h2 class="section-title text-4xl text-text sm:text-5xl">Indicateurs et informations essentielles</h2>
      <p class="mt-4 text-base leading-relaxed text-text-muted">
        Toutes les informations réglementaires et les indicateurs clés sont présentés ici dans un format plus simple et plus lisible.
      </p>
    </div>

    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="border-t border-border">
        <div class="grid grid-cols-1 gap-0">
          {kpiItems.map((item) => (
            <div class="flex items-center justify-between border-b border-border py-5">
              <div class="flex items-center gap-3">
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-white ring-1 ring-border">
                  <Icon name={item.icon} class="h-4 w-4 text-text-muted" />
                </span>
                <span class="text-sm text-text-muted">{item.title}</span>
              </div>
              <span class="text-lg text-text">{item.value}</span>
            </div>
          ))}
        </div>

        <div class="pt-6">
          <p class="text-sm text-text-muted">Référent handicap</p>
          <p class="mt-2 text-base text-text">Amine Es Salah</p>
          <a href="mailto:contact@sodeva.fr" class="mt-1 inline-block text-sm text-text-muted transition-colors hover:text-text">
            contact@sodeva.fr
          </a>
        </div>
      </div>

      <div class="border-t border-border">
        {rnqLinks.map((item) => (
          <a
            href={item.href}
            class="group grid gap-3 border-b border-border py-6 md:grid-cols-[36px_1fr_auto] md:items-start"
          >
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white ring-1 ring-border">
              <Icon name={item.icon} class="h-4 w-4 text-text" />
            </span>
            <div>
              <p class="text-base text-text">{item.title}</p>
              <p class="mt-2 max-w-xl text-sm leading-relaxed text-text-muted">{item.description}</p>
            </div>
            <Icon name="lucide:arrow-right" class="mt-1 h-4 w-4 text-text-muted transition-transform group-hover:translate-x-0.5" />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

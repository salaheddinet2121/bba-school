---
import { Icon } from 'astro-icon/components';
import { featuredBeautyFormations } from '@/data/beauty-formations';

const offers = [
  { formations: '3 formations', price: '1300€' },
  { formations: '4 formations', price: '1650€' },
  { formations: '8 formations', price: '2950€' },
];
---

<section class="py-section bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <p class="section-kicker">Formation a distance</p>
        <h2 class="section-title mt-4 text-4xl text-text sm:text-5xl">Une selection de formations beaute pensee comme une collection</h2>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-text-muted">
          Nous avons contextualise la page autour des codes d&apos;une collection premium:
          techniques esthetiques, apprentissage en ligne, offres claires et parcours orientes pratique.
        </p>
      </div>

      <div class="max-w-sm text-sm leading-relaxed text-text-muted">
        La selection reprend directement votre nouvelle liste de formations beaute, avec les intitules
        reels et les tarifs associes.
      </div>
    </div>

    <div class="border-t border-border">
      {
        featuredBeautyFormations.map((formation) => (
          <article class="grid gap-6 border-b border-border py-8 md:grid-cols-[190px_1fr_auto] md:items-center">
            <div class="relative h-48 overflow-hidden rounded-md bg-accent md:h-56">
              <img
                src={formation.image}
                alt={formation.title}
                class="h-full w-full object-cover"
                loading="lazy"
              />
              <div class="absolute left-4 top-4 bg-white/92 px-3 py-1 text-[0.8rem] text-text">
                {formation.category}
              </div>
            </div>

            <div class="max-w-2xl">
              <h3 class="text-3xl leading-none text-text">{formation.title}</h3>
              <p class="mt-4 text-sm leading-relaxed text-text-muted">
                {formation.note ?? 'Formation disponible au catalogue'}
              </p>
              <p class="mt-5 text-2xl text-text">{formation.price}</p>
            </div>

            <div class="md:justify-self-end">
              <a
                href="/contact"
                class="site-button-secondary inline-flex items-center rounded-none px-5 py-3"
              >
                Demander
                <Icon name="lucide:arrow-right" class="ml-2 h-4 w-4" />
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-12 grid gap-5 border-t border-border pt-8 lg:grid-cols-3">
      {
        offers.map((offer) => (
          <article class="bg-accent px-6 py-7">
            <p class="text-sm text-text-muted">Offre</p>
            <p class="mt-4 text-4xl text-text">{offer.price}</p>
            <p class="mt-3 text-base text-text-muted">{offer.formations}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-border pt-6 text-sm text-text-muted">
      <p>N&apos;hesitez pas a nous contacter pour decouvrir le panel de formations aux choix que nous proposons.</p>
      <a href="/contact" class="site-button-secondary inline-flex items-center rounded-full px-5 py-3 text-[0.72rem]">
        Nous contacter
        <Icon name="lucide:arrow-right" class="ml-2 h-4 w-4" />
      </a>
    </div>
  </div>
</section>

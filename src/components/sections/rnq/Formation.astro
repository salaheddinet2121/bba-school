---
import { Icon } from 'astro-icon/components';
import { getCollection, type CollectionEntry } from 'astro:content';

type FormationEntry = CollectionEntry<'formations'>;

const formations = await getCollection(
  'formations',
  ({ data }: { data: FormationEntry['data'] }) => !data.draft
);

const featuredFormations = [...formations]
  .sort((a: FormationEntry, b: FormationEntry) => a.data.order - b.data.order)
  .slice(0, 3);

const getCardPrice = (formation: FormationEntry) => {
  const prices = [
    formation.data.distancielAvailable ? formation.data.distancielPriceHT ?? formation.data.priceHT : null,
    formation.data.presentielAvailable ? formation.data.presentielPriceHT ?? formation.data.priceHT : null,
  ].filter((value): value is number => typeof value === 'number' && Number.isFinite(value));

  if (prices.length === 0) return formation.data.priceHT;
  return Math.min(...prices);
};
---

<section class="py-section bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-text">Formations populaires</h2>
      <p class="mt-4 text-base text-text-muted max-w-2xl mx-auto">
        Decouvrez nos formations les plus demandees, construites pour des besoins metiers concrets.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        featuredFormations.map((formation) => (
          <a
            href={`/formation/${formation.id}`}
            class="group block overflow-hidden rounded-2xl border border-border bg-background transition-colors hover:border-primary/40"
            aria-label={`Voir ${formation.data.title}`}
          >
            <div class="relative h-42 overflow-hidden bg-surface">
              {formation.data.image ? (
                <img
                  src={formation.data.image}
                  alt={formation.data.title}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-full items-center justify-center bg-linear-to-br from-slate-200 via-slate-300 to-slate-200">
                  <span class="rounded-md bg-background/85 px-3 py-1 text-xs font-semibold text-text-muted">
                    VISUEL
                  </span>
                </div>
              )}
            </div>

            <div class="p-5">
              <div class="mb-3 flex flex-wrap gap-2">
                {formation.data.distancielAvailable && (
                  <span class="rounded-md bg-primary/10 px-2.5 py-1 text-xs font-semibold text-primary-dark">
                    Distanciel
                  </span>
                )}
                {formation.data.presentielAvailable && (
                  <span class="rounded-md bg-success/15 px-2.5 py-1 text-xs font-semibold text-success">
                    Sur place
                  </span>
                )}
              </div>

              <p class="text-xs font-medium uppercase tracking-[0.08em] text-text-muted">
                {formation.data.domain}
                {formation.data.subdomain ? ` - ${formation.data.subdomain}` : ''}
              </p>
              <h3 class="mt-2 min-h-16 text-lg font-semibold leading-snug text-text">
                {formation.data.title}
              </h3>
              <p class="mt-2 text-sm text-text-muted formation-excerpt">{formation.data.description}</p>

              <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-text-muted">
                {formation.data.eligibleCPF && (
                  <span class="inline-flex items-center gap-1.5">
                    <Icon name="lucide:badge-check" class="h-4 w-4" />
                    ELIGIBLE CPF
                  </span>
                )}
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="lucide:clock-3" class="h-4 w-4" />
                  {formation.data.duration}
                </span>
                <span class="inline-flex items-center gap-1.5">
                  <Icon name="lucide:graduation-cap" class="h-4 w-4" />
                  {formation.data.level}
                </span>
              </div>

              <div class="mt-4 border-t border-border pt-4">
                <p class="text-xs uppercase tracking-[0.08em] text-text-muted">A partir de</p>
                <p class="mt-1 text-lg font-bold text-primary-dark">
                  {getCardPrice(formation).toLocaleString('fr-FR')} EUR HT
                </p>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div class="mt-8 text-left">
      <a
        href="/formation"
        class="inline-flex items-center rounded-md border border-border px-4 py-2 text-sm font-medium text-text transition-colors hover:border-primary hover:text-primary"
      >
        Voir le catalogue complet
        <Icon name="lucide:arrow-right" class="ml-2 h-4 w-4" />
      </a>
    </div>
  </div>
</section>

<style>
  .min-h-16 {
    min-height: 4rem;
  }

  .h-42 {
    height: 10.5rem;
  }

  .formation-excerpt {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
</style>

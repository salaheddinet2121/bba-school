---
import { Icon } from 'astro-icon/components';
import { documents } from '@/config/documents';

const certificateUrl = documents.certificatQualiopi;

const points = [
  'Certification Qualiopi active',
  'Éligible CPF — financement simplifié',
  'Kit ou machine offerts selon la formation',
  'Suivi qualité et accompagnement individualisé',
  "Attestation nominative à l'issue de la formation",
];
---

<section id="qualiopi" class="py-20 border-t border-border bg-white">
  <div class="max-w-7xl mx-auto px-6 sm:px-10">
    <div class="grid md:grid-cols-[1fr_auto] gap-12 items-start">

      <div>
        <p class="section-kicker mb-4">Certification Qualiopi</p>
        <h2 class="section-title text-4xl sm:text-5xl text-text max-w-xl">
          Un organisme certifié, un accompagnement sérieux
        </h2>
        <p class="mt-5 text-base text-text-muted max-w-lg leading-relaxed">
          La certification Qualiopi atteste de la qualité de nos processus de formation. Elle garantit un cadre rigoureux, des contenus actualisés et un suivi adapté à chaque apprenant.
        </p>

        <ul class="mt-8 space-y-3">
          {points.map((point) => (
            <li class="flex items-center gap-3">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-text">
                <Icon name="lucide:check" class="h-3 w-3 text-white" />
              </span>
              <span class="text-sm text-text">{point}</span>
            </li>
          ))}
        </ul>

        <a
          href={certificateUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="site-button-secondary mt-8 inline-flex items-center gap-2 rounded-none px-6 py-3"
        >
          Voir le certificat Qualiopi
          <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
        </a>
      </div>

      <div class="flex flex-col items-center gap-6 pt-2">
        <img
          src="/images/qualiopi.webp"
          alt="Certification Qualiopi"
          class="h-32 w-auto object-contain"
          loading="lazy"
        />
        <img
          src="/images/cpf.webp"
          alt="Éligible CPF"
          class="h-20 w-auto object-contain"
          loading="lazy"
        />
      </div>

    </div>
  </div>
</section>

---
import { Icon } from 'astro-icon/components';
import { documents } from '@/config/documents';

const certificateUrl = documents.certificatQualiopi;
const qualityPoints = [
  'Processus pédagogique structuré et suivi qualité.',
  'Accompagnement adapté aux besoins des apprenants.',
  'Amélioration continue des parcours de formation.',
];
---

<section id="qualiopi" class="py-section bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <article class="rounded-2xl border border-border bg-background p-6 sm:p-8">
      <div class="grid gap-8 lg:grid-cols-[220px_1fr] lg:items-center">
        <div class="flex items-center justify-center rounded-xl bg-background p-5">
          <img
            src="/images/qualiopi.webp"
            alt="Certification Qualiopi"
            class="h-36 w-auto object-contain"
            loading="lazy"
          />
        </div>

        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-primary">Bloc Qualiopi</p>
          <h2 class="mt-3 text-3xl font-bold text-text">Une démarche qualité reconnue</h2>
          <p class="mt-4 max-w-3xl text-text-muted">
            SODEVA est certifié Qualiopi au titre des actions de formation. Cette certification confirme
            notre engagement sur la qualité de conception, d'accompagnement et d'évaluation.
          </p>

          <ul class="mt-5 grid gap-3 sm:grid-cols-2">
            {
              qualityPoints.map((point) => (
                <li class="flex items-start gap-2 text-sm text-text-muted">
                  <Icon name="lucide:badge-check" class="mt-0.5 h-4 w-4 shrink-0 text-primary" />
                  <span>{point}</span>
                </li>
              ))
            }
          </ul>

          <a
            href={certificateUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center rounded-md bg-primary px-5 py-2.5 font-medium text-white transition-colors hover:bg-primary-dark"
          >
            Voir le certificat
            <Icon name="lucide:external-link" class="ml-2 h-4 w-4" />
          </a>
        </div>
      </div>
    </article>
  </div>
</section>

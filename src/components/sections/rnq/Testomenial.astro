---
import { Icon } from 'astro-icon/components';

const googleMapsReviewsUrl = 'https://maps.app.goo.gl/4CccE56ZKhN3NRoe9';
const sodevaAddress = '534 Rue Marius Petipa, 34080 Montpellier';
const googleMapsEmbedUrl = 'https://www.google.com/maps?q=SODEVA%20Montpellier&output=embed';

const testimonials = [
  {
    quote:
      "Formation fantastique avec Mohamed, j'ai adoré. Nous avons parcouru les outils IA de manière simple, avec des exemples concrets, applicables immédiatement à n'importe quelle activité. Je repars motivé et enthousiaste, avec des leviers très utiles pour développer mes trois activités. Merci encore pour cette expérience ludique et engageante.",
    author: 'Philippe de Garrigues',
    role: '13 avis Google',
  },
  {
    quote:
      "J'ai particulièrement apprécié la qualité de l'accueil. Les locaux étaient impeccables et très agréables. Les formateurs étaient excellents, de vrais professionnels, avec une pédagogie adaptée au niveau de chacun. Une expérience très positive. Mention spéciale à Eric, formateur de la session, et à Abdel pour l'organisation avec SODEVA.",
    author: 'Ledron Sebastien',
    role: '1 avis Google',
  },
];

const trustIndicators = [
  { label: '8+', detail: "ans d'expérience", icon: 'lucide:calendar-check-2' },
  { label: 'Qualiopi', detail: 'certification active', icon: 'lucide:award' },
  { label: 'RNQ', detail: 'engagement qualité', icon: 'lucide:shield-check' },
];
---

<section class="py-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <article class="mb-8 rounded-2xl border border-border bg-background p-6 sm:p-8">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-primary">
            Avis Google Maps
          </p>
          <h2 class="mt-2 text-2xl font-bold text-text">Consultez nos avis en ligne</h2>
          <p class="mt-2 max-w-3xl text-sm text-text-muted">
            Retrouvez les retours des apprenants et partenaires sur Google Maps. La carte ci-dessous
            reste bloquee tant que vous n'avez pas accepte ce service tiers.
          </p>
        </div>
        <a
          href={googleMapsReviewsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-dark"
        >
          Voir les avis Google
          <Icon name="lucide:external-link" class="ml-2 h-4 w-4" />
        </a>
      </div>

      <div class="mt-6 overflow-hidden rounded-xl border border-border bg-surface">
        <div class="border-b border-border px-6 py-4">
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-primary">Adresse</p>
          <p class="mt-2 text-lg font-semibold text-text">{sodevaAddress}</p>
        </div>
        <div
          class="googlemapsembed h-[320px] w-full"
          data-url={googleMapsEmbedUrl}
          title="Carte Google Maps - SODEVA"
        >
        </div>
        <div class="border-t border-border px-6 py-4">
          <a
            href={`https://maps.google.com/?q=${encodeURIComponent(sodevaAddress)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-md border border-border px-4 py-2 text-sm font-medium text-text transition-colors hover:border-primary hover:text-primary"
          >
            Ouvrir la carte dans Google Maps
            <Icon name="lucide:map-pinned" class="ml-2 h-4 w-4" />
          </a>
        </div>
      </div>
    </article>

    <div class="grid gap-8 lg:grid-cols-[1.05fr_1.4fr]">
      <aside class="rounded-2xl border border-border bg-surface p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.14em] text-primary">Confiance</p>
        <h2 class="mt-3 text-3xl font-bold text-text">Des apprenants satisfaits</h2>
        <p class="mt-3 text-text-muted">
          Nos parcours privilégient l'utilité immédiate, la progression et la qualité de
          l'accompagnement.
        </p>

        <ul class="mt-6 space-y-3">
          {
            trustIndicators.map((item) => (
              <li class="flex items-center gap-3 rounded-lg border border-border bg-background px-4 py-3">
                <div class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-primary/10 text-primary">
                  <Icon name={item.icon} class="h-4 w-4" />
                </div>
                <p class="text-sm text-text-muted">
                  <span class="font-semibold text-text">{item.label}</span> {item.detail}
                </p>
              </li>
            ))
          }
        </ul>
      </aside>

      <div class="grid gap-5 md:grid-cols-2">
        {
          testimonials.map((item, index) => (
            <article
              class="rounded-2xl border border-border bg-background p-6 transition-all duration-300 hover:border-primary/40 hover:shadow-md animate-in"
              style={`animation-delay: ${index * 100}ms`}
            >
              <Icon name="lucide:quote" class="h-6 w-6 text-primary" />
              <blockquote class="mt-4 text-sm leading-relaxed text-text-muted">
                {item.quote}
              </blockquote>
              <p class="mt-5 font-semibold text-text">{item.author}</p>
              <p class="text-sm text-text-muted">{item.role}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .animate-in {
    animation: fade-slide-up 0.6s ease-out both;
  }

  @keyframes fade-slide-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

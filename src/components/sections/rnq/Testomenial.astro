---
import { Icon } from 'astro-icon/components';

const googleMapsReviewsUrl = 'https://maps.app.goo.gl/4CccE56ZKhN3NRoe9';
const sodevaAddress = '534 Rue Marius Petipa, 34080 Montpellier';
const googleMapsEmbedUrl = 'https://www.google.com/maps?q=SODEVA%20Montpellier&output=embed';

const testimonials = [
  {
    quote: "Formation fantastique avec Mohamed, j'ai adoré. Nous avons parcouru les outils IA de manière simple, avec des exemples concrets, applicables immédiatement à n'importe quelle activité. Je repars motivé et enthousiaste.",
    author: 'Philippe de Garrigues',
    role: 'Apprenant',
  },
  {
    quote: "J'ai particulièrement apprécié la qualité de l'accueil. Les formateurs étaient excellents, de vrais professionnels, avec une pédagogie adaptée au niveau de chacun. Une expérience très positive.",
    author: 'Ledron Sebastien',
    role: 'Apprenant',
  },
];

const trustStats = [
  { label: '100%', detail: 'taux de satisfaction' },
  { label: '0%', detail: "taux d'abandon" },
  { label: 'Qualiopi', detail: 'certification active' },
];
---

<section class="border-t border-border bg-white py-24">
  <div class="mx-auto max-w-7xl px-6 sm:px-10">
    <div class="mb-12 max-w-2xl">
      <p class="section-kicker mb-4">Témoignages</p>
      <h2 class="section-title max-w-xl text-4xl text-text sm:text-5xl">
        Des apprenants satisfaits
      </h2>
    </div>

    <div class="grid gap-12 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="border-t border-border">
          {testimonials.map((item) => (
            <article class="border-b border-border py-8">
              <blockquote class="max-w-3xl text-lg leading-relaxed text-text">
                “{item.quote}”
              </blockquote>
              <div class="mt-5">
                <p class="text-sm text-text">{item.author}</p>
                <p class="mt-1 text-sm text-text-muted">{item.role}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-12 grid gap-6 border-t border-border pt-8 sm:grid-cols-3">
          {trustStats.map((s) => (
            <div>
              <p class="section-title text-3xl text-text">{s.label}</p>
              <p class="mt-2 text-sm text-text-muted">{s.detail}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <div class="border-t border-border pt-6">
          <p class="section-kicker mb-3">Localisation</p>
          <p class="text-base text-text">{sodevaAddress}</p>
          <a
            href={googleMapsReviewsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="site-button-secondary mt-5 inline-flex items-center gap-2 rounded-none px-5 py-3"
          >
            Avis Google
            <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
          </a>
        </div>
        <div
          class="googlemapsembed mt-6 h-72 w-full overflow-hidden border border-border bg-surface"
          data-url={googleMapsEmbedUrl}
          title="Carte Google Maps - SODEVA"
        />
      </div>
    </div>
  </div>
</section>
